// Tests for stringlib-compatible additions to data/strx.pf.

import * as Assert from "../src/test/assertions";
import * as StrX from "../src/data/strx";
import * from "io"; // added by gen-test-harness
import * from "../src/test/runner"; // added by gen-test-harness

function optionIntIs(value, expected) {
	match value with
	| None -> false
	| Some found -> found.value == expected
}

//![suite("data/strx extended API")]
//![test("replace handles first all missing and empty needles")]
function testReplaceFunctions() {
	Assert.assertions([
		Assert.assertEqual("a-a.a", StrX.replace("a.a.a", ".", "-")),
		Assert.assertEqual("a-b-c", StrX.replaceAll("a.b.c", ".", "-")),
		Assert.assertEqual("abc", StrX.replace("abc", "z", "!")),
		Assert.assertEqual("abc", StrX.replace("abc", "", "!")),
		Assert.assertEqual("abc", StrX.replaceAll("abc", "", "!"))
	])
}

//![test("character matching and replacement")]
function testCharacterMatching() {
	Assert.assertions([
		Assert.assertTrue(StrX.strMatch("abc1", fn c => c == "1")),
		Assert.assertFalse(StrX.strMatch("abc", fn c => c == "1")),
		Assert.assertEqual("aXcX", StrX.replaceMatch("abcb", fn c => c == "b", fn c => "X"))
	])
}

//![test("takeWhile dropWhile and indexOf")]
function testPrefixScanning() {
	Assert.assertions([
		Assert.assertEqual("123", StrX.takeWhile("123abc", fn c => c >= "0" && c <= "9")),
		Assert.assertEqual("abc", StrX.dropWhile("123abc", fn c => c >= "0" && c <= "9")),
		Assert.assertTrue(optionIntIs(StrX.indexOf("hello world", "world"), 6)),
		Assert.assertNone(StrX.indexOf("hello", "zzz"))
	])
}

//![test("whitespace predicate")]
function testWhitespacePredicate() {
	Assert.assertions([
		Assert.assertTrue(StrX.isWhitespace(" ")),
		Assert.assertTrue(StrX.isWhitespace("\t")),
		Assert.assertTrue(StrX.isWhitespace("\n")),
		Assert.assertFalse(StrX.isWhitespace("x"))
	])
}

// ─────────────────────────────────────────────────────────────────
// GENERATED TEST HARNESS (gen-test-harness.js) — do not edit.
// Lambda-closing lives in pure functions; the generated main has no
// lambdas, so V1's fn-lambda-in-proc purity quirk is never triggered.
// ─────────────────────────────────────────────────────────────────

function __gen_suite_data_strx_extended_API() {
	suite("data/strx extended API", [
		test("replace handles first all missing and empty needles", testReplaceFunctions),
		test("character matching and replacement", testCharacterMatching),
		test("takeWhile dropWhile and indexOf", testPrefixScanning),
		test("whitespace predicate", testWhitespacePredicate)
	])
}

proc main() {
	let __summary = runSuites([__gen_suite_data_strx_extended_API()]);
	printSummary(__summary);
	exitForSummary(__summary);
}
main();
