// test/imapi_test.pf — unit + property tests for data/imapi.pf,
// from the architecture doc's imap test list. Annotation-driven: the harness
// generator emits main; this file must not define one.
//
// Both suites are pure, so tests take zero parameters. Randomized cases use a
// deterministic LCG so every run is reproducible.

import * from "../src/test/assertions";
import * from "../src/data/imapi";
import * as Compat from "../src/compat";
import * from "io"; // added by gen-test-harness
import * from "../src/test/runner"; // added by gen-test-harness

// ── helpers (bootstrap-safe subset) ─────────────────────────────────────────

function maxI(a, b) { if a > b then { a } else { b } }

function optVal(o, dflt) {
	match o with
	| None -> dflt
	| Some v -> v.value
}

// deterministic PRNG
function lcg(s) { (s * 1103515245 + 12345) % 2147483648 }

function iotaFrom(i, acc) {
	if i < 0 then {
		acc
	} else {
		iotaFrom(i - 1, cons(i, acc))
	}
}

function iota(n) {
	iotaFrom(n - 1, [])
}

// AVL invariant: every node balanced and stored height correct
type Bal = { ok, h }
function balAt(m) {
	match m with
	| MLeaf -> Bal { true, 0 }
	| MNode n -> {
		let l = balAt(n.left);
		let r = balAt(n.right);
		let d = l.h - r.h;
		let h = 1 + maxI(l.h, r.h);
		Bal { l.ok && r.ok && d <= 1 && (0 - 1) <= d && n.height == h, h }
	}
}
function isBalanced(m) { balAt(m).ok }

// entries equality, elementwise on scalar fields (no structured ==)
function eqEntriesFrom(a, b, i) {
	match Compat.listAt(a, i) with
	| None -> { match Compat.listAt(b, i) with | None -> true | Some _ -> false }
	| Some ea -> {
		match Compat.listAt(b, i) with
		| None -> false
		| Some eb -> {
			if ea.value.key == eb.value.key && ea.value.value == eb.value.value
			then { eqEntriesFrom(a, b, i + 1) }
			else { false }
		}
	}
}
function eqEntries(a, b) {
	length(a) == length(b) && eqEntriesFrom(a, b, 0)
}

// keys ascending?
function ascendingFrom(ks, i) {
	match Compat.listAt(ks, i + 1) with
	| None -> true
	| Some nxt -> {
		match Compat.listAt(ks, i) with
		| None -> true
		| Some cur -> {
			if cur.value < nxt.value then { ascendingFrom(ks, i + 1) } else { false }
		}
	}
}
function ascending(ks) { ascendingFrom(ks, 0) }

// build a map from n LCG-driven inserts (keys collide on purpose: mod 50)
function buildRandomFrom(n, s, i, m) {
	if i >= n then {
		m
	} else {
		let s2 = lcg(s);
		buildRandomFrom(
			n,
			s2,
			i + 1,
			imiPut(m, s2 % 50, s2 % 1000)
		)
	}
}

function buildRandom(seed, n) {
	buildRandomFrom(n, seed, 0, imiEmpty())
}

// n mixed ops: ~1/3 removes, 2/3 inserts, over a colliding key space
function buildMixedFrom(n, s, i, m) {
	if i >= n then {
		m
	} else {
		let s2 = lcg(s);
		let k = s2 % 37;

		if s2 % 3 == 0 then {
			buildMixedFrom(
				n,
				s2,
				i + 1,
				imiRemove(m, k)
			)
		} else {
			buildMixedFrom(
				n,
				s2,
				i + 1,
				imiPut(m, k, s2)
			)
		}
	}
}

function buildMixed(seed, n) {
	buildMixedFrom(n, seed, 0, imiEmpty())
}

// ── unit tests ──────────────────────────────────────────────────────────────

//![suite("imapi unit")]
//![test("empty lookup returns None")]
function testEmptyLookup() {
	assertions([
		assertNone(imiGet(imiEmpty(), 424242)),
		assertFalse(imiHas(imiEmpty(), 424242)),
		assertEqual(0, length(imiEntries(imiEmpty())))
	]);
}

//![test("insert then get returns inserted value")]
function testInsertGet() {
	let m = imiPut(imiPut(imiPut(imiEmpty(), 2, 2), 1, 1), 3, 3);
	assertions([
		assertEqual(1, optVal(imiGet(m, 1), 0 - 1)),
		assertEqual(2, optVal(imiGet(m, 2), 0 - 1)),
		assertEqual(3, optVal(imiGet(m, 3), 0 - 1)),
		assertTrue(imiHas(m, 2)),
		assertNone(imiGet(m, 4))
	]);
}

//![test("insert same key replaces value")]
function testReplace() {
	let m = imiPut(imiPut(imiEmpty(), 7, 1), 7, 99);
	assertions([
		assertEqual(99, optVal(imiGet(m, 7), 0 - 1)),
		assertEqual(1, length(imiEntries(m)))
	]);
}

//![test("remove deletes key")]
function testRemove() {
	let m = imiPut(imiPut(imiEmpty(), 1, 1), 2, 2);
	let m2 = imiRemove(m, 1);
	assertions([
		assertNone(imiGet(m2, 1)),
		assertFalse(imiHas(m2, 1)),
		assertEqual(2, optVal(imiGet(m2, 2), 0 - 1)),
		assertEqual(1, length(imiEntries(m2)))
	]);
}

//![test("entries are stable sorted")]
function testEntriesSorted() {
	let m = imiFromList([Pair { 50, 5 }, Pair { 30, 3 }, Pair { 10, 1 },
	                     Pair { 40, 4 }, Pair { 20, 2 }]);
	let big = buildRandom(7, 120);
	assertions([
		assertEqual(5, length(imiEntries(m))),
		assertTrue(ascending(imiKeys(m))),
		assertTrue(ascending(imiKeys(big)))
	]);
}

function sequentialMap(i, m) {
	if i >= 64 then {
		m
	} else {
		sequentialMap(i + 1, imiPut(m, i, i))
	}
}

//![test("AVL height invariant holds after randomized inserts/removes")]
function testAvlInvariant() {
	// sequential ascending inserts are the classic degenerate case
	assertions([
		assertTrue(isBalanced(sequentialMap(0, imiEmpty()))),
		assertTrue(isBalanced(buildMixed(1, 200))),
		assertTrue(isBalanced(buildMixed(1234567, 200))),
		assertTrue(isBalanced(buildMixed(987, 300)))
	]);
}

//![test("imiUnion right-biases duplicates")]
function testUnionRightBias() {
	let a = imiFromList([Pair { 100, 1 }, Pair { 555, 1 }]);
	let b = imiFromList([Pair { 555, 2 }, Pair { 200, 3 }]);
	let u = imiUnion(a, b);
	assertions([
		assertEqual(2, optVal(imiGet(u, 555), 0 - 1)),
		assertEqual(1, optVal(imiGet(u, 100), 0 - 1)),
		assertEqual(3, optVal(imiGet(u, 200), 0 - 1)),
		assertEqual(3, length(imiEntries(u)))
	]);
}

// ── property tests ──────────────────────────────────────────────────────────

//![suite("imapi properties")]
//![test("imiFromList(imiEntries(m)) is equivalent to m")]
function testRoundTrip() {
	function holds(seed) {
		let m = buildRandom(seed, 40);
		eqEntries(imiEntries(m), imiEntries(imiFromList(imiEntries(m))))
	}
	assertions(map(fn s => assertTrue(holds(s * 31 + 1)), iota(20)));
}

//![test("imiHas(imiPut(m,k,v),k) is true")]
function testPutHas() {
	function holds(seed) {
		let s2 = lcg(seed);
		let m = buildRandom(seed, 25);
		imiHas(imiPut(m, s2 % 200, s2), s2 % 200)
	}
	assertions(map(fn s => assertTrue(holds(s * 17 + 3)), iota(20)));
}

//![test("removing unknown key preserves existing entries")]
function testRemoveUnknown() {
	function holds(seed) {
		let m = buildRandom(seed, 30);
		// generated keys are all < 2148, never colliding with this one
		eqEntries(imiEntries(m), imiEntries(imiRemove(m, 999999)))
	}
	assertions(map(fn s => assertTrue(holds(s * 13 + 5)), iota(20)));
}

// ─────────────────────────────────────────────────────────────────
// GENERATED TEST HARNESS (gen-test-harness.js) — do not edit.
// Lambda-closing lives in pure functions; the generated main has no
// lambdas, so V1's fn-lambda-in-proc purity quirk is never triggered.
// ─────────────────────────────────────────────────────────────────

function __gen_suite_imapi_unit() {
	suite("imapi unit", [
		test("empty lookup returns None", testEmptyLookup),
		test("insert then get returns inserted value", testInsertGet),
		test("insert same key replaces value", testReplace),
		test("remove deletes key", testRemove),
		test("entries are stable sorted", testEntriesSorted),
		test("AVL height invariant holds after randomized inserts/removes", testAvlInvariant),
		test("imiUnion right-biases duplicates", testUnionRightBias)
	])
}

function __gen_suite_imapi_properties() {
	suite("imapi properties", [
		test("imiFromList(imiEntries(m)) is equivalent to m", testRoundTrip),
		test("imiHas(imiPut(m,k,v),k) is true", testPutHas),
		test("removing unknown key preserves existing entries", testRemoveUnknown)
	])
}

proc main() {
	let __summary = runSuites([__gen_suite_imapi_unit(), __gen_suite_imapi_properties()]);
	printSummary(__summary);
	exitForSummary(__summary);
}
main();
