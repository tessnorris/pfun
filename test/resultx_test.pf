// test/resultx_test.pf — tests for src/data/resultx.pf.

import * as Assert from "../src/test/assertions";
import * from "../src/data/resultx";

generic function resultOkIntIs(result, expected) {
	match result with
	| Ok ok -> ok.value == expected
	| Err _ -> false
}

generic function resultOkStrIs(result, expected) {
	match result with
	| Ok ok -> ok.value == expected
	| Err _ -> false
}

generic function resultErrIs(result, expected) {
	match result with
	| Ok _ -> false
	| Err err -> err.message == expected
}

function optionIntIs(opt, expected) {
	match opt with
	| Some found -> found.value == expected
	| None -> false
}

function intListText(xs) {
	join(map(fn x => __str__(x), xs), ",")
}

generic function resultOkIntListIs(result, expectedText) {
	match result with
	| Ok ok -> intListText(ok.value) == expectedText
	| Err _ -> false
}

//![suite("data/resultx")]

//![test("constructors and predicates")]
function testConstructorsAndPredicates() {
	Assert.assertions([
		Assert.assertTrue(isOk(ok(1))),
		Assert.assertFalse(isOk(err("bad"))),
		Assert.assertTrue(isErr(err("bad"))),
		Assert.assertFalse(isErr(ok(1)))
	])
}

//![test("mapResult and mapErr")]
function testMapResultAndMapErr() {
	Assert.assertions([
		Assert.assertTrue(
			resultOkIntIs(
				mapResult(fn x => x + 1, Ok { 3 }),
				4
			)
		),
		Assert.assertTrue(
			resultErrIs(
				mapResult(fn x => x + 1, Err { "bad" }),
				"bad"
			)
		),
		Assert.assertTrue(
			resultErrIs(
				mapErr(
					fn message => message ++ "!",
					Err { "bad" }
				),
				"bad!"
			)
		),
		Assert.assertTrue(
			resultOkIntIs(
				mapErr(
					fn message => message ++ "!",
					Ok { 3 }
				),
				3
			)
		)
	])
}

//![test("andThenResult and withDefault")]
function testAndThenAndDefault() {
	Assert.assertions([
		Assert.assertTrue(
			resultOkIntIs(
				andThenResult(
					Ok { 3 },
					fn x => Ok { x * 2 }
				),
				6
			)
		),
		Assert.assertTrue(
			resultErrIs(
				andThenResult(
					Err { "bad" },
					fn x => Ok { x * 2 }
				),
				"bad"
			)
		),
		Assert.assertEqual(3, withDefault(0, Ok { 3 })),
		Assert.assertEqual(0, withDefault(0, Err { "bad" }))
	])
}

//![test("option conversion")]
function testOptionConversion() {
	Assert.assertions([
		Assert.assertTrue(
			optionIntIs(toOption(Ok { 3 }), 3)
		),
		Assert.assertNone(toOption(Err { "bad" })),
		Assert.assertTrue(
			resultOkIntIs(
				fromOption("missing", Some { 3 }),
				3
			)
		),
		Assert.assertTrue(
			resultErrIs(
				fromOption("missing", None),
				"missing"
			)
		)
	])
}

//![test("combine keeps first error and otherwise returns right")]
function testCombine() {
	Assert.assertions([
		Assert.assertTrue(
			resultOkStrIs(
				combine(
					Ok { "left" },
					Ok { "right" }
				),
				"right"
			)
		),
		Assert.assertTrue(
			resultErrIs(
				combine(
					Err { "left bad" },
					Ok { "right" }
				),
				"left bad"
			)
		),
		Assert.assertTrue(
			resultErrIs(
				combine(
					Ok { "left" },
					Err { "right bad" }
				),
				"right bad"
			)
		)
	])
}

//![test("collect accumulates values or first error")]
function testCollect() {
	Assert.assertions([
		Assert.assertTrue(
			resultOkIntListIs(
				collect([
					Ok { 1 },
					Ok { 2 },
					Ok { 3 }
				]),
				"1,2,3"
			)
		),
		Assert.assertTrue(
			resultErrIs(
				collect([
					Ok { 1 },
					Err { "bad" },
					Ok { 3 }
				]),
				"bad"
			)
		)
	])
}
