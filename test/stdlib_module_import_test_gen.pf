// Verifies the public V2 source-library spellings.
// The ambient list floor remains available without either import.

import * from "list";
import * from "string";
import * as Assert from "../src/test/assertions";
import * from "io"; // added by gen-test-harness
import * from "../src/test/runner"; // added by gen-test-harness

//![suite("standard list/string module imports")]
//![test("bare imports expose the extended APIs")]
function testBareImports() {
	Assert.assertions([
		Assert.assertEqual(6, sum([1, 2, 3])),
		Assert.assertEqual("1,2,3", join(sort([3, 1, 2]), ",")),
		Assert.assertEqual("hello", trim("  hello  ")),
		Assert.assertEqual("007", padLeft("7", 3, "0")),
		Assert.assertEqual("a-b-c", replaceAll("a.b.c", ".", "-"))
	])
}

// ─────────────────────────────────────────────────────────────────
// GENERATED TEST HARNESS (gen-test-harness.js) — do not edit.
// Lambda-closing lives in pure functions; the generated main has no
// lambdas, so V1's fn-lambda-in-proc purity quirk is never triggered.
// ─────────────────────────────────────────────────────────────────

function __gen_suite_standard_list_string_module_imports() {
	suite("standard list/string module imports", [
		test("bare imports expose the extended APIs", testBareImports)
	])
}

proc main() {
	let __summary = runSuites([__gen_suite_standard_list_string_module_imports()]);
	printSummary(__summary);
	exitForSummary(__summary);
}
main();
