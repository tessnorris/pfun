// test/check/purity_test.pf — Phase 8 purity/effect tests.
//
// These tests cover first-class proc transport, effectful invocation, mutation,
// await placement, fire-and-forget async calls, and lazy-comprehension purity.

import * as Assert from "../src/test/assertions";
import * as H from "./check_helpers";
import * from "io"; // added by gen-test-harness
import * from "../src/test/runner"; // added by gen-test-harness

//![suite("check/purity")]

//![test("pure function calling proc fails")]
function testPureFunctionCallingProcFails() {
	let src = "proc ping() { 0; }\nfunction bad() { ping(); }";
	H.assertHasMessage(H.purityDiags("pure_calls_proc.pf", src), "proc")
}

//![test("proc calling proc succeeds")]
function testProcCallingProcSucceeds() {
	let src = "proc ping() { 0; }\nproc ok() { ping(); }";
	H.assertOkDiags(H.purityDiags("proc_calls_proc.pf", src))
}

//![test("pure function using var fails")]
function testPureFunctionUsingVarFails() {
	let src = "function bad() { var x = 1; x; }";
	H.assertHasMessage(H.purityDiags("pure_var.pf", src), "var")
}

//![test("pure function assigning fails")]
function testPureFunctionAssigningFails() {
	let src = "function bad() { let x = 1; x = 2; x; }";
	H.assertHasMessage(H.purityDiags("pure_assign.pf", src), "Assignment")
}

//![test("pure function using index mutation fails")]
function testPureFunctionIndexMutationFails() {
	let src = "function bad(a) { a[0] = 1; }";
	H.assertHasMessage(H.purityDiags("pure_index_assign.pf", src), "assignment")
}

//![test("proc using mutation succeeds")]
function testProcUsingMutationSucceeds() {
	let src = "proc ok() { var x = 1; x = 2; x; }";
	H.assertOkDiags(H.purityDiags("proc_mutation.pf", src))
}

//![test("await outside async fails")]
function testAwaitOutsideAsyncFails() {
	let src = "async proc later() { 0; }\nproc bad() { await later(); }";
	H.assertHasMessage(H.purityDiags("await_outside_async.pf", src), "await")
}

//![test("await inside async proc succeeds")]
function testAwaitInsideAsyncProcSucceeds() {
	let src = "async proc later() { 0; }\nasync proc ok() { await later(); }";
	H.assertOkDiags(H.purityDiags("await_inside_async.pf", src))
}

//![test("pure code may transport a proc value")]
function testPureCodeMayTransportProcValue() {
	let src = "proc ping() { 0; }\nfunction use(x) { x; }\nfunction bad() { use(ping); }";
	H.assertOkDiags(H.purityDiags("proc_as_arg.pf", src))
}

//![test("proc values may be stored in records")]
function testProcValueInRecordSucceeds() {
	let src = "proc ping() { 0; }\ntype Box = { f };\nlet b = Box { f = ping };";
	H.assertOkDiags(H.purityDiags("proc_in_record.pf", src))
}

//![test("pure code cannot invoke a proc lambda")]
function testPureCodeCannotInvokeProcLambda() {
	let src =
		"let action = proc () -> Unit { };\n"
		++ "function bad() { action(); }";
	H.assertHasMessage(
		H.purityDiags("pure_calls_proc_lambda.pf", src),
		"Pure code"
	)
}

//![test("proc context can invoke a proc lambda")]
function testProcContextCanInvokeProcLambda() {
	let src =
		"let action = proc () -> Unit { };\n"
		++ "proc run() { action(); }";
	H.assertOkDiags(H.purityDiags("proc_calls_proc_lambda.pf", src))
}

//![test("pure code cannot invoke procs through any pipeline")]
function testPureCodeCannotPipeIntoProc() {
	let src =
		"proc touch(value) { value; }\n"
		++ "function badPlain() { 1 |> touch; }\n"
		++ "function badOption() { Some { 1 } |?> touch; }\n"
		++ "function badResult() { Ok { 1 } |!> touch; }";
	H.assertHasMessage(H.purityDiags("pure_proc_pipelines.pf", src), "Pure code")
}

//![test("proc context may invoke procs through wrapper pipelines")]
function testProcContextCanPipeIntoProc() {
	let src =
		"proc touch(value) { value; }\n"
		++ "proc run() {\n"
		++ "  let a = 1 |> touch;\n"
		++ "  let b = Some { 1 } |?> touch;\n"
		++ "  let c = Ok { 1 } |!> touch;\n"
		++ "}";
	H.assertOkDiags(H.purityDiags("proc_pipelines.pf", src))
}

//![test("proc lambda body has procedural mutation context")]
function testProcLambdaBodyAllowsMutation() {
	let src =
		"function make() { "
		++ "let action = proc () -> Int { var x = 0; x = x + 1; x; }; "
		++ "action; }";
	H.assertOkDiags(H.purityDiags("proc_lambda_mutation.pf", src))
}

//![test("await follows proc lambda async flag")]
function testProcLambdaAwaitFollowsAsyncFlag() {
	let good =
		"async proc later() { 0; }\n"
		++ "let action = async proc () -> Int { await later(); };";
	let bad =
		"async proc later() { 0; }\n"
		++ "let action = proc () -> Int { await later(); };";
	Assert.assertions([
		Assert.assertEqual(0, length(H.purityDiags("async_proc_lambda.pf", good))),
		Assert.assertTrue(length(H.purityDiags("sync_proc_lambda_await.pf", bad)) > 0)
	])
}

//![test("fire and forget async proc accepted in proc context")]
function testFireAndForgetAccepted() {
	let src = "async proc slow() { 0; }\nproc run() { slow(); }";
	H.assertOkDiags(H.purityDiags("fire_and_forget.pf", src))
}

//![test("lazy comprehension body calling proc fails")]
function testLazyComprehensionBodyCallingProcFails() {
	let src = "proc touch(x) { x; }\nproc build(xs) { let ys = lazy [touch(x) for x <- xs]; ys; }";
	H.assertHasMessage(H.purityDiags("lazy_proc_call.pf", src), "proc")
}

//![test("private extern function with exported safe wrapper succeeds")]
function testPrivateExternWrapperSucceeds() {
	let src = "extern function nativeThing(x: Str) -> Any\nfunction decode(x) { x; }\nexport function safe(x) { decode(nativeThing(x)); }";
	H.assertOkDiags(H.purityDiags("extern_wrapper.pf", src))
}

//![test("export extern rejected before purity")]
function testExportExternRejectedBeforePurity() {
	let src = "export extern function nativeThing(x: Str) -> Any";
	H.assertHasDiag(H.purityDiags("export_extern.pf", src))
}

// ─────────────────────────────────────────────────────────────────
// GENERATED TEST HARNESS (gen-test-harness.js) — do not edit.
// Lambda-closing lives in pure functions; the generated main has no
// lambdas, so V1's fn-lambda-in-proc purity quirk is never triggered.
// ─────────────────────────────────────────────────────────────────

function __gen_suite_check_purity() {
	suite("check/purity", [
		test("pure function calling proc fails", testPureFunctionCallingProcFails),
		test("proc calling proc succeeds", testProcCallingProcSucceeds),
		test("pure function using var fails", testPureFunctionUsingVarFails),
		test("pure function assigning fails", testPureFunctionAssigningFails),
		test("pure function using index mutation fails", testPureFunctionIndexMutationFails),
		test("proc using mutation succeeds", testProcUsingMutationSucceeds),
		test("await outside async fails", testAwaitOutsideAsyncFails),
		test("await inside async proc succeeds", testAwaitInsideAsyncProcSucceeds),
		test("pure code may transport a proc value", testPureCodeMayTransportProcValue),
		test("proc values may be stored in records", testProcValueInRecordSucceeds),
		test("pure code cannot invoke a proc lambda", testPureCodeCannotInvokeProcLambda),
		test("proc context can invoke a proc lambda", testProcContextCanInvokeProcLambda),
		test("pure code cannot invoke procs through any pipeline", testPureCodeCannotPipeIntoProc),
		test("proc context may invoke procs through wrapper pipelines", testProcContextCanPipeIntoProc),
		test("proc lambda body has procedural mutation context", testProcLambdaBodyAllowsMutation),
		test("await follows proc lambda async flag", testProcLambdaAwaitFollowsAsyncFlag),
		test("fire and forget async proc accepted in proc context", testFireAndForgetAccepted),
		test("lazy comprehension body calling proc fails", testLazyComprehensionBodyCallingProcFails),
		test("private extern function with exported safe wrapper succeeds", testPrivateExternWrapperSucceeds),
		test("export extern rejected before purity", testExportExternRejectedBeforePurity)
	])
}

proc main() {
	let __summary = runSuites([__gen_suite_check_purity()]);
	printSummary(__summary);
	exitForSummary(__summary);
}
main();
