function testMixedIndexedListFails() {
	let src = "type Indexed = { index, generic value };\nlet a = Indexed { index = 1, value = \"hello\" };\nlet b = Indexed { index = 2, value = 42 };\nlet xs = [a, b];";
	H.assertHasDiag(H.typeDiags("indexed_mixed_list.pf", src))
}

