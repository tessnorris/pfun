function testEqualityOnFunctionsFails() {
	let src = "function eq(a, b) { a == b; }\nfunction g() { 1; }\nlet t = eq(g, g);";
	H.assertHasMessage(H.typeDiags("deferred_eq_bad.pf", src), "equality")
}

//![test("match binder payload field access succeeds")]
function testBinderPayloadFieldAccessSucceeds() {
	let src = "type T = { | A: n | B }\nfunction h(t) { match t with | A a -> a.n | B -> 0; }\nlet r = h(B) + 1;";
	H.assertOkDiags(H.typeDiags("binder_payload.pf", src))
}

//![test("guard using binder payload succeeds")]
function testGuardUsingBinderPayloadSucceeds() {
	let src = "type T = { | A: n | B }\nfunction h(t) { match t with | A a where a.n > 0 -> 1 | _ -> 0; }";
	H.assertOkDiags(H.typeDiags("binder_guard.pf", src))
}

//![test("binder widens to union at call sites")]
function testBinderWidensToUnion() {
	let src = "type T = { | A: n | B }\nfunction use(t) { match t with | A a -> a.n | B -> 0; }\nfunction h(t) { match t with | A a -> use(a) | B -> 0; }";
	H.assertOkDiags(H.typeDiags("binder_widen.pf", src))
}

//![test("mixed variant list joins to union")]
function testMixedVariantListJoins() {
	let src = "type T = { | A: n | B }\nlet xs = cons(A { n = 1 }, cons(B, []));\nlet k = length(xs) + 1;";
	H.assertOkDiags(H.typeDiags("variant_list_join.pf", src))
}

//![test("constructor payload field access succeeds")]
function testConstructorPayloadFieldAccessSucceeds() {
	let src = "type T = { | A: n | B }\nlet x = A { n = 1 };\nlet y = x.n + 1;";
	H.assertOkDiags(H.typeDiags("ctor_field.pf", src))
}

//![test("variant-returning function widens to union")]
function testVariantReturnWidensToUnion() {
	let src = "type T = { | A: n | B }\nfunction use(t) { match t with | A a -> a.n | B -> 0; }\nfunction mk() { A { n = 1 } }\nlet r = use(mk()) + 1;";
	H.assertOkDiags(H.typeDiags("variant_return.pf", src))
}

//![test("trailing if joins sibling variants")]
function testTrailingIfJoinsSiblingVariants() {
	let src = "type T = { | A: n | B }\nfunction use(t) { match t with | A a -> a.n | B -> 0; }\nlet g = fn c => { if c then { A { n = 1 } } else { B } };\nlet r = use(g(true)) + 1;";
	H.assertOkDiags(H.typeDiags("trailing_if_join.pf", src))
}

//![test("combined unions join component errors through Result")]
function testCombinedUnionResultJoin() {
	let src =
		"type FileError = { | Missing: message | Denied: message }\n"
		++ "type JsonError = { | InvalidJson: message }\n"
		++ "type AppError = { ...FileError ...JsonError | InvalidConfig: message }\n"
		++ "function fail(kind) {\n"
		++ "  if kind == 0 then { Err { Missing { \"missing\" } } }\n"
		++ "  else if kind == 1 then { Err { InvalidJson { \"json\" } } }\n"
		++ "  else { Err { InvalidConfig { \"config\" } } }\n"
		++ "}\n"
		++ "function message(result) {\n"
		++ "  match result with\n"
		++ "  | Ok _ -> \"ok\"\n"
		++ "  | Err failure -> failure.message.message;\n"
		++ "}\n"
		++ "function kind(result) {\n"
		++ "  match result with\n"
		++ "  | Ok _ -> \"ok\"\n"
		++ "  | Err failure -> match failure.message with\n"
		++ "    | Missing _ -> \"file\"\n"
		++ "    | Denied _ -> \"denied\"\n"
		++ "    | InvalidJson _ -> \"json\"\n"
		++ "    | InvalidConfig _ -> \"config\";\n"
		++ "}\n"
		++ "let text = kind(fail(0)) ++ message(fail(1));";
	H.assertOkDiags(
		H.typeDiagsWithBuiltins("combined_result_join.pf", src)
	)
}

//![test("combined union shared fields require every variant")]
function testCombinedUnionSharedFieldMustBeTotal() {
	let src =
		"type AError = { | AProblem: message }\n"
		++ "type BError = { | BProblem: code }\n"
		++ "type AppError = { ...AError ...BError }\n"
		++ "function choose(flag) { if flag then { AProblem { \"a\" } } else { BProblem { 2 } } }\n"
		++ "function bad(value) { value.message }\n"
		++ "let x = bad(choose(true));";
	H.assertHasMessage(
		H.typeDiags("combined_shared_field_bad.pf", src),
		"no field 'message'"
	)
}

//![test("combined union does not flow into a component union")]
function testCombinedUnionReverseFlowFails() {
	let src =
		"type AError = { | AProblem }\n"
		++ "type BError = { | BProblem }\n"
		++ "type AppError = { ...AError ...BError }\n"
		++ "let choose = proc (flag: Bool) -> AppError { if flag then { AProblem } else { BProblem } };\n"
		++ "let onlyA = proc (value: AError) -> Unit { };\n"
		++ "proc run() { onlyA(choose(false)); }";
	H.assertHasMessage(
		H.typeDiags("combined_reverse_flow.pf", src),
		"AppError"
	)
}

//![test("combined union inclusion cycles fail")]
function testCombinedUnionCycleFails() {
	let src =
		"type AError = { ...BError | AProblem }\n"
		++ "type BError = { ...AError | BProblem }";
	H.assertHasMessage(
		H.typeDiags("combined_cycle.pf", src),
		"Cyclic union inclusion"
	)
}

//![test("combined union duplicate variants fail")]
function testCombinedUnionDuplicateVariantFails() {
	let src =
		"type AError = { | Same: message }\n"
		++ "type BError = { | Same: message }\n"
		++ "type AppError = { ...AError ...BError }";
	H.assertHasMessage(
		H.typeDiags("combined_duplicate.pf", src),
		"duplicate variant 'Same'"
	)
}

//![test("sibling variant field access fails")]
function testSiblingVariantFieldAccessFails() {
	let src = "type T = { | A: n | B }\nfunction h(t) { match t with | A a -> a.n | B b -> b.n; }";
	H.assertHasMessage(H.typeDiags("sibling_field.pf", src), "no field")
}

//![test("binder field typo fails")]
function testBinderFieldTypoFails() {
	let src = "type T = { | A: n | B }\nfunction h(t) { match t with | A a -> a.zzz | B -> 0; }";
	H.assertHasMessage(H.typeDiags("binder_typo.pf", src), "no field")
}

//![test("variant passed to wrong union fails")]
function testVariantPassedToWrongUnionFails() {
	let src = "type T = { | A: n | B }\ntype U2 = { | X: m | Y }\nfunction f(u) { match u with | X x -> 1 | Y -> 2; }\nfunction h(t) { match t with | A a -> f(a) | B -> 0; }";
	H.assertHasDiag(H.typeDiags("variant_wrong_union.pf", src))
}

//![test("union with trailing slots keeps arity across arms")]
function testUnionTrailingSlotArity() {
	let src = "type T = { | B | A: generic v }\nfunction h(t) { match t with | B -> 0 | A a -> 1; }\nlet r = h(A { v = 2 }) + h(B);";
	H.assertOkDiags(H.typeDiags("slot_arity.pf", src))
}

//![test("builtin Option match and payload succeed")]
function testBuiltinOptionMatchSucceeds() {
	let src = "function f(o) { match o with | Some x -> x.value | None -> 0; }\nlet r = f(Some { value = 3 }) + 1;";
	H.assertOkDiags(H.typeDiagsWithBuiltins("builtin_option.pf", src))
}

//![test("builtin core exports are ambient")]
function testBuiltinCoreExportsAmbient() {
	let src = "let n = nthU([1, 2], 0) + 1;\nlet c = __str__(chrU(13));\nlet o = nth([1, 2], 0);";
	H.assertOkDiags(H.typeDiagsWithBuiltins("builtin_ambient.pf", src))
}

//![test("builtin NativeError variants and accessors succeed")]
function testBuiltinNativeErrorSucceeds() {
	let src =
		"function describe(error) {\n"
		++ "  match error with\n"
		++ "  | NativeIoError found -> found.operation ++ \"/\" ++ found.message\n"
		++ "  | NativeProcessError found -> found.operation ++ \"/\" ++ found.message\n"
		++ "  | NativeTimerError found -> found.operation ++ \"/\" ++ found.message\n"
		++ "  | NativeBufferError found -> found.operation ++ \"/\" ++ found.message\n"
		++ "  | NativeJsonError found -> found.operation ++ \"/\" ++ found.message\n"
		++ "  | NativeNumericError found -> found.operation ++ \"/\" ++ found.message\n"
		++ "  | NativePlatformError found -> found.operation ++ \"/\" ++ found.message;\n"
		++ "}\n"
		++ "let error = NativeIoError { operation = \"readFile\", message = \"denied\" };\n"
		++ "let text = describe(error) ++ nativeErrorOperation(error) ++ nativeErrorMessage(error);";
	H.assertOkDiags(H.typeDiagsWithBuiltins("builtin_native_error.pf", src))
}

//![test("sleep and timer procedures return NativeError Results")]
function testBuiltinTimerResultsSucceed() {
	let src =
		"import * from \"async\";\n"
		++ "import * from \"timer\";\n"
		++ "async proc run() {\n"
		++ "  match await sleep(0) with\n"
		++ "  | Err failure -> nativeErrorMessage(failure.message)\n"
		++ "  | Ok _ -> {\n"
		++ "      match setTimer(0, proc () -> Unit { }) with\n"
		++ "      | Err failure -> nativeErrorMessage(failure.message)\n"
		++ "      | Ok timer -> match clearTimer(timer.value) with\n"
		++ "        | Err failure -> nativeErrorMessage(failure.message)\n"
		++ "        | Ok _ -> \"ok\";\n"
		++ "    }\n"
		++ "}\n";
	H.assertOkDiags(
		H.typeDiagsWithBuiltins("builtin_timer_results.pf", src)
	)
}

//![test("timer scheduling Result must be unwrapped")]
function testBuiltinTimerResultMustBeUnwrapped() {
	let src =
		"import * from \"timer\";\n"
		++ "proc run() {\n"
		++ "  let handle = setTimer(0, proc () -> Unit { });\n"
		++ "  clearTimer(handle);\n"
		++ "}\n";
	H.assertHasMessage(
		H.typeDiagsWithBuiltins("builtin_timer_unwrap.pf", src),
		"Result<TimerHandle, NativeError>"
	)
}

//![test("console procedures return NativeError Results")]
function testBuiltinConsoleResultsSucceed() {
	let src =
		"import * from \"io\";\n"
		++ "proc run() {\n"
		++ "  match println(\"hello\") with\n"
		++ "  | Err failure -> nativeErrorMessage(failure.message)\n"
		++ "  | Ok _ -> match scanln() with\n"
		++ "    | Err failure -> nativeErrorMessage(failure.message)\n"
		++ "    | Ok input -> match input.value with\n"
		++ "      | None -> \"eof\"\n"
		++ "      | Some line -> line.value;\n"
		++ "}\n";
	H.assertOkDiags(
		H.typeDiagsWithBuiltins("builtin_console_results.pf", src)
	)
}

//![test("stdin Result must be unwrapped before Option")]
function testBuiltinStdinResultMustBeUnwrapped() {
	let src =
		"import * from \"io\";\n"
		++ "function legacyLine(input) {\n"
		++ "  match input with\n"
		++ "  | None -> \"eof\"\n"
		++ "  | Some line -> line.value;\n"
		++ "}\n"
		++ "proc run() {\n"
		++ "  legacyLine(scanln());\n"
		++ "}\n";
	H.assertHasMessage(
		H.typeDiagsWithBuiltins("builtin_stdin_unwrap.pf", src),
		"Result<Option<Str>, NativeError>"
	)
}

//![test("builtin Pair construction and field access succeed")]
function testBuiltinPairSucceeds() {
	let src = "let p = Pair { 1, \"x\" };\nlet k = p.key + 1;\nlet v = p.value ++ \"!\";";
	H.assertOkDiags(H.typeDiags("builtin_pair.pf", src))
}

//![test("builtin Pair field type mismatch fails")]
function testBuiltinPairMismatchFails() {
	let src = "let p = Pair { 1, \"x\" };\nlet k = p.value + 1;";
	H.assertHasDiag(H.typeDiags("builtin_pair_bad.pf", src))
}

//![test("match resolves shared variants from the subject union")]
function testSharedVariantNamesUseSubjectUnion() {
	let src =
		"import * from \"file\";\n"
		++ "proc inspect() {\n"
		++ "  match fileOpen(\"ignored.txt\", Read) with\n"
		++ "  | Ok opened -> {\n"
		++ "      match readLine(opened.value) with\n"
		++ "      | ReadOk line -> line.value ++ \"\"\n"
		++ "      | ReadEof _ -> \"\"\n"
		++ "      | ReadErr failed -> nativeErrorMessage(failed.message);\n"
		++ "    }\n"
		++ "  | Err failed -> nativeErrorMessage(failed.message);\n"
		++ "}\n";
	let diags = H.typeDiagsWithBuiltins(
		"shared_variant_subject.pf",
		src
	);

	match Compat.uncons(diags) with
	| None -> {
		Assert.assertions([
			Assert.assertEqual(0, 0)
		])
	}
	| Some cell -> {
		Assert.assertions([
			Assert.assertEqual(
				"",
				cell.value.key.message
			)
		])
	}
}

