// test/check/types_test.pf — Phase 7 type-checker tests.
//
// These tests cover the architecture's type-inference integration and golden
// diagnostic cases: monomorphic vs generic functions, generic record slots,
// `+`/`++` rules, field constraints, and unknown constructors.

import * as Assert from "../src/test/assertions";
import * as H from "./check_helpers";
import * as Compat from "../src/compat";
import * from "io"; // added by gen-test-harness
import * from "../src/test/runner"; // added by gen-test-harness

//![suite("check/types")]

//![test("numeric plus succeeds")]
function testNumericPlusSucceeds() {
	H.assertOkDiags(H.typeDiags("numeric_plus.pf", "let x = 1 + 2;"))
}

//![test("string plus fails")]
function testStringPlusFails() {
	H.assertHasMessage(H.typeDiags("string_plus.pf", "let x = \"a\" + \"b\";"), "numeric")
}

//![test("string concat succeeds")]
function testStringConcatSucceeds() {
	H.assertOkDiags(H.typeDiags("string_concat.pf", "let x = \"a\" ++ \"b\";"))
}

//![test("ordinary forward pipe typechecks as a unary call")]
function testForwardPipeSucceeds() {
	let src =
		"function addOne(value) { value + 1 }\n"
		++ "function double(value) { value * 2 }\n"
		++ "let answer = 3 |> addOne |> double;\n"
		++ "let checked = answer + 1;";
	H.assertOkDiags(H.typeDiags("forward_pipe.pf", src))
}

//![test("pipelines require exactly one argument")]
function testPipelineArityFails() {
	let src = "function add(a, b) { a + b }\nlet answer = 3 |> add;";
	H.assertHasMessage(H.typeDiags("pipe_arity.pf", src), "exactly one")
}

//![test("Option pipe is transparent then maps and flattens")]
function testOptionPipelineSucceeds() {
	let src =
		"function positive(value) {\n"
		++ "  if value > 0 then { Some { value } } else { None }\n"
		++ "}\n"
		++ "function double(value) { value * 2 }\n"
		++ "function underTen(value) {\n"
		++ "  if value < 10 then { Some { value } } else { None }\n"
		++ "}\n"
		++ "let found = 3 |?> positive |?> double |?> underTen;\n"
		++ "let missing = -1 |?> positive |?> double |?> underTen;\n"
		++ "function render(value) {\n"
		++ "  match value with | Some item -> item.value + 1 | None -> 0;\n"
		++ "}\n"
		++ "let total = render(found) + render(missing);";
	H.assertOkDiags(H.typeDiagsWithBuiltins("option_pipeline.pf", src))
}

//![test("Result pipe maps raw stages and joins wrapped errors")]
function testResultPipelineJoinsErrors() {
	let src =
		"type ShapeError = { | BadShape: message }\n"
		++ "type WindowError = { | BadWindow: message }\n"
		++ "type PipelineError = { ...ShapeError ...WindowError }\n"
		++ "function shape(rows) {\n"
		++ "  if length(rows) == 0 then { Err { BadShape { \"empty\" } } }\n"
		++ "  else { Ok { reverse(rows) } }\n"
		++ "}\n"
		++ "function flip(rows) { reverse(rows) }\n"
		++ "function window(rows) {\n"
		++ "  if length(rows) == 0 then { Err { BadWindow { \"short\" } } }\n"
		++ "  else { Ok { rows } }\n"
		++ "}\n"
		++ "let result = [[1, 2]] |!> shape |!> flip |!> window;\n"
		++ "function render(value) {\n"
		++ "  match value with\n"
		++ "  | Ok rows -> length(rows.value)\n"
		++ "  | Err failure -> match failure.message with\n"
		++ "    | BadShape _ -> 1\n"
		++ "    | BadWindow _ -> 2;\n"
		++ "}\n"
		++ "let answer = render(result) + 1;";
	H.assertOkDiags(H.typeDiagsWithBuiltins("result_pipeline.pf", src))
}

//![test("Option and Result pipelines do not cross wrappers")]
function testPipelineWrapperMismatchFails() {
	let src = "function addOne(value) { value + 1 }\nlet bad = Some { 1 } |!> addOne;";
	H.assertHasDiag(H.typeDiags("pipeline_wrapper_mismatch.pf", src))
}

//![test("concat number fails")]
function testConcatNumberFails() {
	H.assertHasMessage(H.typeDiags("concat_number.pf", "let x = \"count: \" ++ 3;"), "++")
}

//![test("generic function instantiates independently")]
function testGenericFunctionInstantiatesIndependently() {
	let src = "generic function id(x) { x; }\nlet a = id(1);\nlet b = id(\"x\");";
	H.assertOkDiags(H.typeDiags("generic_id.pf", src))
}

//![test("monomorphic function used at incompatible types fails")]
function testMonomorphicFunctionIncompatibleTypesFails() {
	let src = "function id(x) { x; }\nlet a = id(1);\nlet b = id(\"x\");";
	H.assertHasDiag(H.typeDiags("mono_id_bad.pf", src))
}

//![test("recursive accumulator must match its predeclared signature")]
function testRecursiveAccumulatorConflictFails() {
	let src =
		"function loop(xs, acc) {\n"
		++ "  match xs with\n"
		++ "  | [] -> acc\n"
		++ "  | [first, ...rest] -> loop(rest, 1)\n"
		++ "}\n"
		++ "let value = loop([], \"text\") ++ \"!\";";

	H.assertHasDiag(
		H.typeDiags(
			"recursive_accumulator_bad.pf",
			src
		)
	)
}

//![test("generic recursive accumulator must remain monomorphic within one call")]
function testGenericRecursiveAccumulatorConflictFails() {
	let src =
		"generic function loop(xs, acc) {\n"
		++ "  match xs with\n"
		++ "  | [] -> acc\n"
		++ "  | [first, ...rest] -> loop(rest, 1)\n"
		++ "}\n"
		++ "let value = loop([], \"text\") ++ \"!\";";

	H.assertHasDiag(
		H.typeDiags(
			"generic_recursive_accumulator_bad.pf",
			src
		)
	)
}

//![test("well typed recursive accumulator succeeds")]
function testRecursiveAccumulatorSucceeds() {
	let src =
		"function loop(xs, acc) {\n"
		++ "  match xs with\n"
		++ "  | [] -> acc\n"
		++ "  | [first, ...rest] -> loop(rest, acc + 1)\n"
		++ "}\n"
		++ "let value = loop([1, 2], 0) + 1;";

	H.assertOkDiags(
		H.typeDiags(
			"recursive_accumulator_ok.pf",
			src
		)
	)
}

//![test("generic recursive function instantiates independently")]
function testGenericRecursiveFunctionInstantiatesIndependently() {
	let src =
		"generic function lastOr(xs, fallback) {\n"
		++ "  match xs with\n"
		++ "  | [] -> fallback\n"
		++ "  | [first, ...rest] -> lastOr(rest, fallback)\n"
		++ "}\n"
		++ "let a = lastOr([1], 0) + 1;\n"
		++ "let b = lastOr([\"x\"], \"\") ++ \"!\";";

	H.assertOkDiags(
		H.typeDiags(
			"generic_recursive_independent.pf",
			src
		)
	)
}

//![test("Indexed Str list succeeds")]
function testIndexedStrListSucceeds() {
	let src = "type Indexed = { index, generic value };\nlet a = Indexed { index = 1, value = \"hello\" };\nlet b = Indexed { index = 2, value = \"world\" };\nlet xs = [a, b];";
	H.assertOkDiags(H.typeDiags("indexed_str_list.pf", src))
}

