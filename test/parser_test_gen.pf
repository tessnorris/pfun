// test/parser_test.pf — tests for src/syntax/parser.pf
// and src/syntax/ast.pf.

import * as Assert from "../src/test/assertions";
import * as Lex from "../src/syntax/lexer";
import * as Parser from "../src/syntax/parser";
import * as A from "../src/syntax/ast";
import * as Compat from "../src/compat";
import * from "io"; // added by gen-test-harness
import * from "../src/test/runner"; // added by gen-test-harness

function parseSource(source) {
	match Lex.lex("parser-test.pf", source) with
	| LexErr e -> ParseErr { e.diags }
	| LexOk toks -> Parser.parseModule("parser-test.pf", toks.tokens)
}

function parseOkAssertion(source) {
	match parseSource(source) with
	| ParseOk _ -> Assert.assertTrue(true)
	| ParseErr e -> {
		Assert.fail(
			"Expected parse success, got "
			++ __str__(length(e.diags))
			++ " diagnostic(s)."
		)
	}
}

function parseErrAssertion(source) {
	match parseSource(source) with
	| ParseOk _ -> Assert.fail("Expected parse failure.")
	| ParseErr e -> Assert.assertTrue(length(e.diags) > 0)
}

function stmtAt(module, index) {
	Compat.listAt(module.stmts, index)
}

function assertModuleStmtCount(source, expected) {
	match parseSource(source) with
	| ParseErr e -> {
		Assert.fail(
			"Expected parse success, got "
			++ __str__(length(e.diags))
			++ " diagnostic(s)."
		)
	}
	| ParseOk parsed -> Assert.assertEqual(expected, length(parsed.module.stmts))
}

function assertTimesRhs(expr) {
	match expr with
	| EBinary times -> {
		if times.op == "*" then {
			Assert.assertTrue(true)
		} else {
			Assert.fail("Expected multiplication on right side of plus.")
		}
	}
	| _ -> Assert.fail("Expected multiplication on right side of plus.")
}

function assertPlusExpr(expr) {
	match expr with
	| EBinary plus -> {
		if plus.op == "+" then {
			assertTimesRhs(plus.rhs)
		} else {
			Assert.fail("Expected plus expression.")
		}
	}
	| _ -> Assert.fail("Expected binary init.")
}

function assertLetStmtPrecedence(stmt) {
	match stmt with
	| SLet letStmt -> assertPlusExpr(letStmt.init)
	| _ -> Assert.fail("Expected let statement.")
}

function assertLetPrecedence(source) {
	match parseSource(source) with
	| ParseErr e -> {
		Assert.fail(
			"Expected parse success, got "
			++ __str__(length(e.diags))
			++ " diagnostic(s)."
		)
	}
	| ParseOk parsed -> {
		match stmtAt(parsed.module, 0) with
		| None -> Assert.fail("Expected first statement.")
		| Some s -> assertLetStmtPrecedence(s.value)
	}
}

function assertKinds(firstKind, secondKind) {
	match firstKind with
	| PureFn k1 -> {
		match secondKind with
		| ProcFn k2 -> {
			if k1.isMemo && k1.isGeneric && k2.isAsync && k2.isGeneric then {
				Assert.assertTrue(true)
			} else {
				Assert.fail(
					"Expected generic memo function and generic async proc flags."
				)
			}
		}
		| _ -> Assert.fail("Expected proc kind on second declaration.")
	}
	| _ -> Assert.fail("Expected pure function kind on first declaration.")
}

function assertFunctionStmtPair(firstStmt, secondStmt) {
	match firstStmt with
	| SFun firstFn -> {
		match secondStmt with
		| SFun secondFn -> assertKinds(firstFn.kind, secondFn.kind)
		| _ -> Assert.fail("Expected second function statement.")
	}
	| _ -> Assert.fail("Expected first function statement.")
}

function assertFunctionKinds(source) {
	match parseSource(source) with
	| ParseErr e -> {
		Assert.fail(
			"Expected parse success, got "
			++ __str__(length(e.diags))
			++ " diagnostic(s)."
		)
	}
	| ParseOk parsed -> {
		match stmtAt(parsed.module, 0) with
		| None -> Assert.fail("Expected first function.")
		| Some first -> {
			match stmtAt(parsed.module, 1) with
			| None -> Assert.fail("Expected second function.")
			| Some second -> {
				assertFunctionStmtPair(first.value, second.value)
			}
		}
	}
}

generic function assertCompGuard(comp) {
	match comp.mode with
	| LazyList -> {
		match comp.guard with
		| Some _ -> {
			if length(comp.gens) == 1 then {
				Assert.assertTrue(true)
			} else {
				Assert.fail("Expected one comprehension generator.")
			}
		}
		| None -> Assert.fail("Expected comprehension guard.")
	}
	| _ -> Assert.fail("Expected LazyList mode.")
}

function assertLazyInit(expr) {
	match expr with
	| EComp comp -> assertCompGuard(comp)
	| _ -> Assert.fail("Expected comprehension expression.")
}

function assertLazyStmt(stmt) {
	match stmt with
	| SLet letStmt -> assertLazyInit(letStmt.init)
	| _ -> Assert.fail("Expected let statement.")
}

function assertLazyComprehension(source) {
	match parseSource(source) with
	| ParseErr e -> {
		Assert.fail(
			"Expected parse success, got "
			++ __str__(length(e.diags))
			++ " diagnostic(s)."
		)
	}
	| ParseOk parsed -> {
		match stmtAt(parsed.module, 0) with
		| None -> Assert.fail("Expected let statement.")
		| Some s -> assertLazyStmt(s.value)
	}
}

function assertRestPattern(pattern) {
	match pattern with
	| PList p -> {
		match p.rest with
		| Some _ -> Assert.assertTrue(true)
		| None -> Assert.fail("Expected list rest pattern.")
	}
	| _ -> Assert.fail("Expected list pattern.")
}

generic function assertSecondMatchArm(matchExpr) {
	match Compat.listAt(matchExpr.arms, 1) with
	| None -> Assert.fail("Expected second match arm.")
	| Some arm -> assertRestPattern(arm.value.pattern)
}

function assertMatchInit(expr) {
	match expr with
	| EMatch matchExpr -> assertSecondMatchArm(matchExpr)
	| _ -> Assert.fail("Expected match expression.")
}

function assertMatchStmt(stmt) {
	match stmt with
	| SLet letStmt -> assertMatchInit(letStmt.init)
	| _ -> Assert.fail("Expected let statement.")
}

function assertMatchListPatterns(source) {
	match parseSource(source) with
	| ParseErr e -> {
		Assert.fail(
			"Expected parse success, got "
			++ __str__(length(e.diags))
			++ " diagnostic(s)."
		)
	}
	| ParseOk parsed -> {
		match stmtAt(parsed.module, 0) with
		| None -> Assert.fail("Expected let statement.")
		| Some s -> assertMatchStmt(s.value)
	}
}

function assertIfStmt(stmt) {
	match stmt with
	| SIf ifStmt -> {
		match ifStmt.elseS with
		| Some els -> {
			if length(ifStmt.thenS) == 1 && length(els.value) == 1 then {
				Assert.assertTrue(true)
			} else {
				Assert.fail("Expected one statement in each branch.")
			}
		}
		| None -> Assert.fail("Expected else branch.")
	}
	| _ -> Assert.fail("Expected if statement.")
}

function assertIfStatementBlocks(source) {
	match parseSource(source) with
	| ParseErr e -> {
		Assert.fail(
			"Expected parse success, got "
			++ __str__(length(e.diags))
			++ " diagnostic(s)."
		)
	}
	| ParseOk parsed -> {
		match stmtAt(parsed.module, 0) with
		| None -> Assert.fail("Expected if statement.")
		| Some s -> assertIfStmt(s.value)
	}
}

function assertTypeAndExtern(inner, thirdStmt) {
	match inner with
	| SType t -> {
		match thirdStmt with
		| SExtern _ -> Assert.assertTrue(t.isOpaque)
		| _ -> Assert.fail("Expected extern statement.")
	}
	| _ -> Assert.fail("Expected exported type.")
}

function assertExportAndExtern(secondStmt, thirdStmt) {
	match secondStmt with
	| SExport exported -> assertTypeAndExtern(exported.inner, thirdStmt)
	| _ -> Assert.fail("Expected export statement.")
}

function assertImportExportExtern(firstStmt, secondStmt, thirdStmt) {
	match firstStmt with
	| SImport _ -> assertExportAndExtern(secondStmt, thirdStmt)
	| _ -> Assert.fail("Expected import statement.")
}

function assertThreeImportStmts(module) {
	match stmtAt(module, 0) with
	| None -> Assert.fail("Expected import statement.")
	| Some first -> {
		match stmtAt(module, 1) with
		| None -> Assert.fail("Expected export statement.")
		| Some second -> {
			match stmtAt(module, 2) with
			| None -> Assert.fail("Expected extern statement.")
			| Some third -> {
				assertImportExportExtern(
					first.value,
					second.value,
					third.value
				)
			}
		}
	}
}

function assertImportTypeExternExport(source) {
	match parseSource(source) with
	| ParseErr e -> {
		Assert.fail(
			"Expected parse success, got "
			++ __str__(length(e.diags))
			++ " diagnostic(s)."
		)
	}
	| ParseOk parsed -> assertThreeImportStmts(parsed.module)
}

//![suite("syntax/parser")]
//![test("parses let statements with Pratt precedence")]
function testLetPrecedence() {
	Assert.assertions([
		assertLetPrecedence("let x = 1 + 2 * 3;")
	])
}

//![test("parses function and proc declaration flags")]
function testFunctionAndProcFlags() {
	Assert.assertions([
		assertFunctionKinds(
			"generic memo function f(x, y) { x; }\n"
			++ "generic async proc run(x) { await x; }"
		)
	])
}

//![test("parses typed sync and async proc lambdas and proc types")]
function testProcLambdaForms() {
	Assert.assertions([
		parseOkAssertion(
			"let step = proc (x: Int) -> Int { x + 1; }; "
			++ "let later = async proc () -> Unit { }; "
			++ "extern proc schedule(action: proc() -> Unit) -> Unit; "
			++ "extern proc scheduleAsync(action: async proc(Int) -> Unit) -> Unit;"
		),
		assertModuleStmtCount(
			"let step = proc (x: Int) -> Int { x + 1; }; "
			++ "let later = async proc () -> Unit { };",
			2
		)
	])
}

//![test("parses lazy comprehensions")]
function testLazyComprehension() {
	Assert.assertions([
		assertLazyComprehension(
			"let xs = lazy [x * 2 for x <- ys where x > 0];"
		)
	])
}

//![test("parses match list patterns")]
function testMatchListPatterns() {
	Assert.assertions([
		assertMatchListPatterns(
			"let result = match xs with "
			++ "| [] -> 0 | [h, ...t] -> h;"
		)
	])
}

//![test("parses statement if blocks")]
function testIfStatementBlocks() {
	Assert.assertions([
		assertIfStatementBlocks(
			"if true then { let x = 1; } else { let y = 2; }"
		)
	])
}

//![test("parses imports exported opaque types and extern signatures")]
function testImportTypeExternExport() {
	let source =
		"import { foo as bar, baz } from \"./dep\";\n"
		++ "export opaque type Box = { generic value };\n"
		++ "extern function nativeParse(x: Str) -> Int;";
	Assert.assertions([
		assertImportTypeExternExport(source),
		assertModuleStmtCount(source, 3)
	])
}

//![test("parses record dict array call field and index forms")]
function testCompositeAndPostfixForms() {
	let source =
		"let r = Foo { name = \"x\", value = 1 }; "
		++ "let d = dict { \"a\" -> 1 }; "
		++ "let a = array { 1, 2 }; "
		++ "let x = f(r.name, a[0]);";
	Assert.assertions([
		parseOkAssertion(source),
		assertModuleStmtCount(source, 4)
	])
}

//![test("rejects unsupported or malformed parser inputs")]
function testParseErrors() {
	Assert.assertions([
		parseErrAssertion(
			"export extern function native(x: Str) -> Int;"
		),
		parseErrAssertion("export var counter = 0;"),
		parseErrAssertion("let f = proc x => x;"),
		parseErrAssertion("let f = proc (x) -> Int { x; };"),
		parseErrAssertion("let f = async function (x: Int) -> Int { x; };"),
		parseErrAssertion("let xs = lazy foo();"),
		parseErrAssertion("if true then let x = 1;"),
		parseErrAssertion("let x = match xs with | [...rest] -> 0;")
	])
}

// ── format string interpolation ─────────────────────────────────────────────

//![test("parses interpolations containing embedded literals with braces")]
function testFmtEmbeddedBraces() {
	Assert.assertions([
		parseOkAssertion("let a = $\"x {join(xs, \"}\")} y\";"),
		parseOkAssertion("let b = $\"n {f(\"{\")} m\";"),
		parseOkAssertion("let c = $\"p {g('}')} q\";"),
		parseOkAssertion("let d = $\"t {n > 2 ? \"big\" : \"small\"}\";")
	])
}

//![test("rejects malformed format string interpolations")]
function testFmtInterpolationErrors() {
	Assert.assertions([
		parseErrAssertion("let a = $\"bad {} interp\";"),
		parseErrAssertion("let b = $\"junk {1 2}\";"),
		parseErrAssertion("let c = $\"esc \\q\";")
	])
}

// ─────────────────────────────────────────────────────────────────
// GENERATED TEST HARNESS (gen-test-harness.js) — do not edit.
// Lambda-closing lives in pure functions; the generated main has no
// lambdas, so V1's fn-lambda-in-proc purity quirk is never triggered.
// ─────────────────────────────────────────────────────────────────

function __gen_suite_syntax_parser() {
	suite("syntax/parser", [
		test("parses let statements with Pratt precedence", testLetPrecedence),
		test("parses function and proc declaration flags", testFunctionAndProcFlags),
		test("parses typed sync and async proc lambdas and proc types", testProcLambdaForms),
		test("parses lazy comprehensions", testLazyComprehension),
		test("parses match list patterns", testMatchListPatterns),
		test("parses statement if blocks", testIfStatementBlocks),
		test("parses imports exported opaque types and extern signatures", testImportTypeExternExport),
		test("parses record dict array call field and index forms", testCompositeAndPostfixForms),
		test("rejects unsupported or malformed parser inputs", testParseErrors),
		test("parses interpolations containing embedded literals with braces", testFmtEmbeddedBraces),
		test("rejects malformed format string interpolations", testFmtInterpolationErrors)
	])
}

proc main() {
	let __summary = runSuites([__gen_suite_syntax_parser()]);
	printSummary(__summary);
	exitForSummary(__summary);
}
main();
