// test/check/check_test.pf — Phase 10 master checker tests.
//
// These tests verify that check.pf coordinates type, purity, exhaustiveness, and
// interface production, and that checkGraph skips dependents of failed modules
// instead of checking against missing interfaces.

import * as Assert from "../src/test/assertions";
import * as H from "./check_helpers";
import * as Check from "../src/check/check";
import * as Iface from "../src/check/iface";
import * as ModGraph from "../src/graph/modgraph";
import * as IMS from "../src/data/imaps";
import * from "io"; // added by gen-test-harness
import * from "../src/test/runner"; // added by gen-test-harness

//![suite("check/check")]

//![test("successful module produces interface")]
function testSuccessfulModuleProducesInterface() {
	let src = "export function one() { 1; }";
	let unit = H.checkUnit("success_iface.pf", src);
	Assert.assertions([
		Assert.assertEqual(0, length(unit.diags)),
		Assert.assertTrue(Iface.hasExport(unit.iface, "one"))
	])
}

//![test("failed module produces diagnostics")]
function testFailedModuleProducesDiagnostics() {
	let src = "export let bad = \"a\" + \"b\";";
	let unit = H.checkUnit("failed_module.pf", src);
	Assert.assertions([
		Assert.assertTrue(length(unit.diags) > 0),
		Assert.assertFalse(Iface.hasExport(unit.iface, "bad"))
	])
}

//![test("diagnostics from type and purity are batched")]
function testDiagnosticsFromAllPassesAreBatched() {
	let src = "proc ping() { 0; }\nfunction bad() { ping(); }\nlet x = \"a\" + \"b\";";
	let unit = H.checkUnit("batched_diags.pf", src);
	Assert.assertions([Assert.assertTrue(length(unit.diags) >= 2)])
}

//![test("dependency interface is visible to importer")]
function testDependencyInterfaceVisible() {
	match H.rawSource("dep.pf", "export function one() { 1; }") with
	| RawErr e -> Assert.assertions([Assert.assertEqual(0, length(e.diags))])
	| RawOk dep -> {
		match H.rawSource("main.pf", "import { one } from \"./dep\";\nlet x = one();") with
		| RawErr bad -> Assert.assertions([Assert.assertEqual(0, length(bad.diags))])
		| RawOk main -> {
			let graph = Check.checkGraph([dep.raw, main.raw], H.emptyBuiltinIfaces());
			Assert.assertions([Assert.assertEqual(0, length(graph.diags))])
		}
	}
}

//![test("record imported from dependency supports field access")]
function testImportedRecordFieldAccess() {
	let libSrc = "export type Box = { value }; export function box() { Box { value = 41 } }";
	let libUnit = H.checkUnit("boxlib.pf", libSrc);
	let deps = IMS.imsPut(H.emptyDeps(), "./boxlib", libUnit.iface);
	let mainSrc = "import { box } from \"./boxlib\"; let answer = box().value + 1;";
	let unit = H.checkUnitWithDeps("main.pf", mainSrc, deps);
	Assert.assertions([
		Assert.assertEqual(0, length(libUnit.diags)),
		Assert.assertEqual(0, length(unit.diags))
	])
}

//![test("dependent of failed module is skipped once")]
function testDependentOfFailedModuleSkippedOnce() {
	match H.rawSource("baddep.pf", "export let bad = \"a\" + \"b\";") with
	| RawErr e -> Assert.assertions([Assert.assertEqual(0, length(e.diags))])
	| RawOk dep -> {
		match H.rawSource("usesbad.pf", "import { bad } from \"./baddep\";\nlet x = bad;") with
		| RawErr bad -> Assert.assertions([Assert.assertEqual(0, length(bad.diags))])
		| RawOk main -> {
			let graph = Check.checkGraph([dep.raw, main.raw], H.emptyBuiltinIfaces());
			Assert.assertions([
				Assert.assertTrue(length(graph.diags) >= 2),
				Assert.assertTrue(H.hasDiagContaining(graph.diags, "Skipping module"))
			])
		}
	}
}

//![test("missing dependency interface skips module")]
function testMissingDependencyInterfaceSkipsModule() {
	match H.rawSource("usesmissing.pf", "import { nope } from \"./missing\";\nlet x = nope;") with
	| RawErr bad -> Assert.assertions([Assert.assertEqual(0, length(bad.diags))])
	| RawOk main -> {
		let graph = Check.checkGraph([main.raw], H.emptyBuiltinIfaces());
		Assert.assertions([
			Assert.assertTrue(length(graph.diags) == 1),
			Assert.assertTrue(H.hasDiagContaining(graph.diags, "no checked interface"))
		])
	}
}

//![test("checkTopo forwards graph diagnostics")]
function testCheckTopoForwardsGraphDiagnostics() {
	match H.rawSource("usesmissing2.pf", "import { nope } from \"./missing\";\nlet x = nope;") with
	| RawErr bad -> Assert.assertions([Assert.assertEqual(0, length(bad.diags))])
	| RawOk main -> {
		let topo = ModGraph.toposort([main.raw]);
		let graph = Check.checkTopo(topo, H.emptyBuiltinIfaces());
		Assert.assertions([Assert.assertTrue(length(graph.diags) > 0)])
	}
}

//![test("union imported from dependency is matchable")]
function testImportedUnionMatchable() {
	let libSrc = "export type Color = { | Red: n | Blue }";
	let libUnit = H.checkUnit("colorlib.pf", libSrc);
	let deps = IMS.imsPut(H.emptyDeps(), "./colorlib", libUnit.iface);
	let mainSrc = "import * as C from \"./colorlib\";\nfunction f(c) { match c with | Red r -> r.n | Blue -> 0; }\nlet x = f(Blue) + f(Red { n = 2 });";
	let unit = H.checkUnitWithDeps("main.pf", mainSrc, deps);
	Assert.assertions([
		Assert.assertEqual(0, length(unit.diags))
	])
}

// ─────────────────────────────────────────────────────────────────
// GENERATED TEST HARNESS (gen-test-harness.js) — do not edit.
// Lambda-closing lives in pure functions; the generated main has no
// lambdas, so V1's fn-lambda-in-proc purity quirk is never triggered.
// ─────────────────────────────────────────────────────────────────

function __gen_suite_check_check() {
	suite("check/check", [
		test("successful module produces interface", testSuccessfulModuleProducesInterface),
		test("failed module produces diagnostics", testFailedModuleProducesDiagnostics),
		test("diagnostics from type and purity are batched", testDiagnosticsFromAllPassesAreBatched),
		test("dependency interface is visible to importer", testDependencyInterfaceVisible),
		test("record imported from dependency supports field access", testImportedRecordFieldAccess),
		test("dependent of failed module is skipped once", testDependentOfFailedModuleSkippedOnce),
		test("missing dependency interface skips module", testMissingDependencyInterfaceSkipsModule),
		test("checkTopo forwards graph diagnostics", testCheckTopoForwardsGraphDiagnostics),
		test("union imported from dependency is matchable", testImportedUnionMatchable)
	])
}

proc main() {
	let __summary = runSuites([__gen_suite_check_check()]);
	printSummary(__summary);
	exitForSummary(__summary);
}
main();
