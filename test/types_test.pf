// test/check/types_test.pf — Phase 7 type-checker tests.
//
// These tests cover the architecture's type-inference integration and golden
// diagnostic cases: monomorphic vs generic functions, generic record slots,
// `+`/`++` rules, field constraints, and unknown constructors.

import * as Assert from "../src/test/assertions";
import * as H from "./check_helpers";
import * as Compat from "../src/compat";

//![suite("check/types")]

//![test("numeric plus succeeds")]
function testNumericPlusSucceeds() {
	H.assertOkDiags(H.typeDiags("numeric_plus.pf", "let x = 1 + 2;"))
}

//![test("string plus fails")]
function testStringPlusFails() {
	H.assertHasMessage(H.typeDiags("string_plus.pf", "let x = \"a\" + \"b\";"), "numeric")
}

//![test("string concat succeeds")]
function testStringConcatSucceeds() {
	H.assertOkDiags(H.typeDiags("string_concat.pf", "let x = \"a\" ++ \"b\";"))
}

//![test("concat number fails")]
function testConcatNumberFails() {
	H.assertHasMessage(H.typeDiags("concat_number.pf", "let x = \"count: \" ++ 3;"), "++")
}

//![test("generic function instantiates independently")]
function testGenericFunctionInstantiatesIndependently() {
	let src = "generic function id(x) { x; }\nlet a = id(1);\nlet b = id(\"x\");";
	H.assertOkDiags(H.typeDiags("generic_id.pf", src))
}

//![test("monomorphic function used at incompatible types fails")]
function testMonomorphicFunctionIncompatibleTypesFails() {
	let src = "function id(x) { x; }\nlet a = id(1);\nlet b = id(\"x\");";
	H.assertHasDiag(H.typeDiags("mono_id_bad.pf", src))
}

//![test("recursive accumulator must match its predeclared signature")]
function testRecursiveAccumulatorConflictFails() {
	let src =
		"function loop(xs, acc) {\n"
		++ "  match xs with\n"
		++ "  | [] -> acc\n"
		++ "  | [first, ...rest] -> loop(rest, 1)\n"
		++ "}\n"
		++ "let value = loop([], \"text\") ++ \"!\";";

	H.assertHasDiag(
		H.typeDiags(
			"recursive_accumulator_bad.pf",
			src
		)
	)
}

//![test("generic recursive accumulator must remain monomorphic within one call")]
function testGenericRecursiveAccumulatorConflictFails() {
	let src =
		"generic function loop(xs, acc) {\n"
		++ "  match xs with\n"
		++ "  | [] -> acc\n"
		++ "  | [first, ...rest] -> loop(rest, 1)\n"
		++ "}\n"
		++ "let value = loop([], \"text\") ++ \"!\";";

	H.assertHasDiag(
		H.typeDiags(
			"generic_recursive_accumulator_bad.pf",
			src
		)
	)
}

//![test("well typed recursive accumulator succeeds")]
function testRecursiveAccumulatorSucceeds() {
	let src =
		"function loop(xs, acc) {\n"
		++ "  match xs with\n"
		++ "  | [] -> acc\n"
		++ "  | [first, ...rest] -> loop(rest, acc + 1)\n"
		++ "}\n"
		++ "let value = loop([1, 2], 0) + 1;";

	H.assertOkDiags(
		H.typeDiags(
			"recursive_accumulator_ok.pf",
			src
		)
	)
}

//![test("generic recursive function instantiates independently")]
function testGenericRecursiveFunctionInstantiatesIndependently() {
	let src =
		"generic function lastOr(xs, fallback) {\n"
		++ "  match xs with\n"
		++ "  | [] -> fallback\n"
		++ "  | [first, ...rest] -> lastOr(rest, fallback)\n"
		++ "}\n"
		++ "let a = lastOr([1], 0) + 1;\n"
		++ "let b = lastOr([\"x\"], \"\") ++ \"!\";";

	H.assertOkDiags(
		H.typeDiags(
			"generic_recursive_independent.pf",
			src
		)
	)
}

//![test("Indexed Str list succeeds")]
function testIndexedStrListSucceeds() {
	let src = "type Indexed = { index, generic value };\nlet a = Indexed { index = 1, value = \"hello\" };\nlet b = Indexed { index = 2, value = \"world\" };\nlet xs = [a, b];";
	H.assertOkDiags(H.typeDiags("indexed_str_list.pf", src))
}

//![test("mixed Indexed list fails")]
function testMixedIndexedListFails() {
	let src = "type Indexed = { index, generic value };\nlet a = Indexed { index = 1, value = \"hello\" };\nlet b = Indexed { index = 2, value = 42 };\nlet xs = [a, b];";
	H.assertHasDiag(H.typeDiags("indexed_mixed_list.pf", src))
}

//![test("field not found fails")]
function testFieldNotFoundFails() {
	let src = "type User = { name };\nlet u = User { name = \"Ada\" };\nlet n = u.age;";
	H.assertHasMessage(H.typeDiags("field_not_found.pf", src), "field")
}

//![test("unknown variant fails")]
function testUnknownVariantFails() {
	let src = "let x = Missing { value = 1 };";
	H.assertHasMessage(H.typeDiags("unknown_variant.pf", src), "Unknown")
}

//![test("exported non-generic open field constraint fails")]
function testExportedNonGenericOpenFieldConstraintFails() {
	let src = "type A = { value };\ntype B = { value, extra };\nexport function f(x) { x.value; }";
	H.assertHasDiag(H.typeDiags("open_export.pf", src))
}

//![test("format string expression is Str")]
function testFormatStringIsString() {
	let src = "let x = $\"count: {3}\" ++ \"!\";";
	H.assertOkDiags(H.typeDiags("format_string_type.pf", src))
}

//![test("expression lambda body infers")]
function testExpressionLambdaBodyInfers() {
	let src = "let f = fn x => x + 1;\nlet y = f(2) + 1;";
	H.assertOkDiags(H.typeDiags("lambda_expr.pf", src))
}

//![test("typed proc lambda can be stored transported and called")]
function testProcLambdaTransportAndCall() {
	let src =
		"type Handler = { generic action };\n"
		++ "function carry(action) { Handler { action = action } }\n"
		++ "let step = proc (x: Int) -> Int { x + 1; };\n"
		++ "let handler = carry(step);\n"
		++ "proc run() { let y = handler.action(2) + 1; y; }";
	H.assertOkDiags(H.typeDiags("proc_lambda_transport.pf", src))
}

//![test("proc lambda return annotation is enforced")]
function testProcLambdaReturnMismatchFails() {
	let src = "let bad = proc (x: Int) -> Str { x + 1; };";
	H.assertHasDiag(H.typeDiags("proc_lambda_return_bad.pf", src))
}

//![test("sync and async proc values remain distinct")]
function testProcLambdaAsyncMismatchFails() {
	let src =
		"let sync = proc () -> Unit { };\n"
		++ "let later = async proc () -> Unit { };\n"
		++ "let both = [sync, later];";
	H.assertHasMessage(
		H.typeDiags("proc_lambda_async_mismatch.pf", src),
		"async"
	)
}

//![test("proc lambda calls enforce exact arity")]
function testProcLambdaArityFails() {
	let src =
		"let step = proc (x: Int) -> Int { x + 1; };\n"
		++ "proc run() { step(); }";
	H.assertHasMessage(H.typeDiags("proc_lambda_arity.pf", src), "argument")
}

//![test("trailing if block is the lambda value")]
function testTrailingIfBlockIsLambdaValue() {
	let src = "let g = fn x => { if x then { 1 } else { 2 } };\nlet y = g(true) + 1;";
	H.assertOkDiags(H.typeDiags("lambda_trailing_if.pf", src))
}

//![test("trailing if branch type mismatch fails")]
function testTrailingIfBranchMismatchFails() {
	let src = "let g = fn x => { if x then { 1 } else { \"a\" } };";
	H.assertHasDiag(H.typeDiags("lambda_trailing_if_bad.pf", src))
}

//![test("reduce fold with trailing if succeeds")]
function testReduceFoldWithTrailingIfSucceeds() {
	let src = "function cw(pred, xs) { reduce(fn n, x => { if pred(x) then { n + 1 } else { n } }, 0, xs) }\nlet c = cw(fn v => v == 1, [1, 2]) + 1;";
	H.assertOkDiags(H.typeDiags("fold_trailing_if.pf", src))
}

//![test("statement if discards branch values")]
function testStatementIfDiscardsBranchValues() {
	let src = "proc p(c) { if c then { 1; } else { \"x\"; } 0; }";
	H.assertOkDiags(H.typeDiags("stmt_if_discard.pf", src))
}

//![test("float int arithmetic promotes to Float")]
function testFloatIntPromotes() {
	let src = "let x = 1.5 + 2;\nlet y = 2 + 1.5;\nlet s = x + y;";
	H.assertOkDiags(H.typeDiags("float_promotion.pf", src))
}

//![test("unary minus on Float succeeds")]
function testUnaryMinusFloatSucceeds() {
	let src = "let z = -1.5;\nlet w = z + 0.5;";
	H.assertOkDiags(H.typeDiags("unary_minus_float.pf", src))
}

//![test("unary minus on Str fails")]
function testUnaryMinusStrFails() {
	let src = "let z = -\"a\";";
	H.assertHasMessage(H.typeDiags("unary_minus_str.pf", src), "numeric")
}

//![test("deferred field access resolved by call succeeds")]
function testDeferredFieldAccessResolvedSucceeds() {
	let src = "type User = { name };\nfunction getName(u) { u.name; }\nlet n = getName(User { name = \"Ada\" }) ++ \"!\";";
	H.assertOkDiags(H.typeDiags("deferred_field_ok.pf", src))
}

//![test("deferred field access to missing field fails")]
function testDeferredFieldAccessMissingFails() {
	let src = "type User = { name };\nfunction f(u) { u.age; }\nlet n = f(User { name = \"x\" });";
	H.assertHasMessage(H.typeDiags("deferred_field_bad.pf", src), "no field")
}

//![test("deferred equatable resolved by call succeeds")]
function testDeferredEquatableResolvedSucceeds() {
	let src = "function eq(a, b) { a == b; }\nlet t = eq(1, 2);";
	H.assertOkDiags(H.typeDiags("deferred_eq_ok.pf", src))
}

//![test("equality on functions fails")]
function testEqualityOnFunctionsFails() {
	let src = "function eq(a, b) { a == b; }\nfunction g() { 1; }\nlet t = eq(g, g);";
	H.assertHasMessage(H.typeDiags("deferred_eq_bad.pf", src), "equality")
}

//![test("match binder payload field access succeeds")]
function testBinderPayloadFieldAccessSucceeds() {
	let src = "type T = { | A: n | B }\nfunction h(t) { match t with | A a -> a.n | B -> 0; }\nlet r = h(B) + 1;";
	H.assertOkDiags(H.typeDiags("binder_payload.pf", src))
}

//![test("guard using binder payload succeeds")]
function testGuardUsingBinderPayloadSucceeds() {
	let src = "type T = { | A: n | B }\nfunction h(t) { match t with | A a where a.n > 0 -> 1 | _ -> 0; }";
	H.assertOkDiags(H.typeDiags("binder_guard.pf", src))
}

//![test("binder widens to union at call sites")]
function testBinderWidensToUnion() {
	let src = "type T = { | A: n | B }\nfunction use(t) { match t with | A a -> a.n | B -> 0; }\nfunction h(t) { match t with | A a -> use(a) | B -> 0; }";
	H.assertOkDiags(H.typeDiags("binder_widen.pf", src))
}

//![test("mixed variant list joins to union")]
function testMixedVariantListJoins() {
	let src = "type T = { | A: n | B }\nlet xs = cons(A { n = 1 }, cons(B, []));\nlet k = length(xs) + 1;";
	H.assertOkDiags(H.typeDiags("variant_list_join.pf", src))
}

//![test("constructor payload field access succeeds")]
function testConstructorPayloadFieldAccessSucceeds() {
	let src = "type T = { | A: n | B }\nlet x = A { n = 1 };\nlet y = x.n + 1;";
	H.assertOkDiags(H.typeDiags("ctor_field.pf", src))
}

//![test("variant-returning function widens to union")]
function testVariantReturnWidensToUnion() {
	let src = "type T = { | A: n | B }\nfunction use(t) { match t with | A a -> a.n | B -> 0; }\nfunction mk() { A { n = 1 } }\nlet r = use(mk()) + 1;";
	H.assertOkDiags(H.typeDiags("variant_return.pf", src))
}

//![test("trailing if joins sibling variants")]
function testTrailingIfJoinsSiblingVariants() {
	let src = "type T = { | A: n | B }\nfunction use(t) { match t with | A a -> a.n | B -> 0; }\nlet g = fn c => { if c then { A { n = 1 } } else { B } };\nlet r = use(g(true)) + 1;";
	H.assertOkDiags(H.typeDiags("trailing_if_join.pf", src))
}

//![test("sibling variant field access fails")]
function testSiblingVariantFieldAccessFails() {
	let src = "type T = { | A: n | B }\nfunction h(t) { match t with | A a -> a.n | B b -> b.n; }";
	H.assertHasMessage(H.typeDiags("sibling_field.pf", src), "no field")
}

//![test("binder field typo fails")]
function testBinderFieldTypoFails() {
	let src = "type T = { | A: n | B }\nfunction h(t) { match t with | A a -> a.zzz | B -> 0; }";
	H.assertHasMessage(H.typeDiags("binder_typo.pf", src), "no field")
}

//![test("variant passed to wrong union fails")]
function testVariantPassedToWrongUnionFails() {
	let src = "type T = { | A: n | B }\ntype U2 = { | X: m | Y }\nfunction f(u) { match u with | X x -> 1 | Y -> 2; }\nfunction h(t) { match t with | A a -> f(a) | B -> 0; }";
	H.assertHasDiag(H.typeDiags("variant_wrong_union.pf", src))
}

//![test("union with trailing slots keeps arity across arms")]
function testUnionTrailingSlotArity() {
	let src = "type T = { | B | A: generic v }\nfunction h(t) { match t with | B -> 0 | A a -> 1; }\nlet r = h(A { v = 2 }) + h(B);";
	H.assertOkDiags(H.typeDiags("slot_arity.pf", src))
}

//![test("builtin Option match and payload succeed")]
function testBuiltinOptionMatchSucceeds() {
	let src = "function f(o) { match o with | Some x -> x.value | None -> 0; }\nlet r = f(Some { value = 3 }) + 1;";
	H.assertOkDiags(H.typeDiagsWithBuiltins("builtin_option.pf", src))
}

//![test("builtin core exports are ambient")]
function testBuiltinCoreExportsAmbient() {
	let src = "let n = nthU([1, 2], 0) + 1;\nlet c = __str__(chrU(13));\nlet o = nth([1, 2], 0);";
	H.assertOkDiags(H.typeDiagsWithBuiltins("builtin_ambient.pf", src))
}

//![test("builtin Pair construction and field access succeed")]
function testBuiltinPairSucceeds() {
	let src = "let p = Pair { 1, \"x\" };\nlet k = p.key + 1;\nlet v = p.value ++ \"!\";";
	H.assertOkDiags(H.typeDiags("builtin_pair.pf", src))
}

//![test("builtin Pair field type mismatch fails")]
function testBuiltinPairMismatchFails() {
	let src = "let p = Pair { 1, \"x\" };\nlet k = p.value + 1;";
	H.assertHasDiag(H.typeDiags("builtin_pair_bad.pf", src))
}

//![test("match resolves shared variants from the subject union")]
function testSharedVariantNamesUseSubjectUnion() {
	let src =
		"import * from \"file\";\n"
		++ "proc inspect() {\n"
		++ "  match fileOpen(\"ignored.txt\", Read) with\n"
		++ "  | Ok opened -> {\n"
		++ "      match readLine(opened.value) with\n"
		++ "      | Ok line -> line.value ++ \"\"\n"
		++ "      | Eof _ -> \"\"\n"
		++ "      | Err failed -> failed.message;\n"
		++ "    }\n"
		++ "  | Err failed -> failed.message;\n"
		++ "}\n";
	let diags = H.typeDiagsWithBuiltins(
		"shared_variant_subject.pf",
		src
	);

	match Compat.uncons(diags) with
	| None -> {
		Assert.assertions([
			Assert.assertEqual(0, 0)
		])
	}
	| Some cell -> {
		Assert.assertions([
			Assert.assertEqual(
				"",
				cell.value.key.message
			)
		])
	}
}
