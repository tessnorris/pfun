function __gen_suite_data_resultx() {
	suite("data/resultx", [
		test("constructors and predicates", testConstructorsAndPredicates),
		test("mapResult and mapErr", testMapResultAndMapErr),
		test("andThenResult and withDefault", testAndThenAndDefault),
		test("option conversion", testOptionConversion),
		test("combine keeps first error and otherwise returns right", testCombine),
		test("collect accumulates values or first error", testCollect)
	])
}

