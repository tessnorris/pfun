/*
  theme_studio.pf — client-only semantic web theme selector.

  The user edits a semantic Theme record. Pure functions translate that theme
  into live preview styles and generated CSS. No backend, no protocol, no DB.
*/

import * from "$PFUN_HOME/lib/htmllib";
import * from "$PFUN_HOME/lib/viewlib";
import * from "$PFUN_HOME/lib/tea";

// ── Types ────────────────────────────────────────────────────────────────────

type Theme = {
  name,

  headingFont,
  bodyFont,
  monoFont,

  background,
  surface,
  primarySurface,

  text,
  mutedText,

  primary,
  secondary,
  accent,

  success,
  warning,
  danger,

  border,

  radius,
  spacing,
  shadow,
  fontSize
}

type Model = { theme, previewMode }
type UpdateResult = { model, cmd }

type ThemeField = {
  | FieldName
  | FieldHeadingFont
  | FieldBodyFont
  | FieldMonoFont
  | FieldBackground
  | FieldSurface
  | FieldPrimarySurface
  | FieldText
  | FieldMutedText
  | FieldPrimary
  | FieldSecondary
  | FieldAccent
  | FieldSuccess
  | FieldWarning
  | FieldDanger
  | FieldBorder
  | FieldRadius
  | FieldSpacing
  | FieldShadow
  | FieldFontSize
}

type Msg = {
  | SetTheme : field, value
  | SetPreviewMode : value
  | ApplyPreset : value
  | ResetTheme
}

