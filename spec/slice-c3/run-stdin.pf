// Slice C3 stdin forwarding probe.

import * from "io";

proc main() {
	match scanln() with
	| Err failure -> println(
		"stdin:error:" ++ nativeErrorMessage(failure.message)
	)
	| Ok input -> match input.value with
		| None -> println("stdin:eof")
		| Some line -> println("stdin:" ++ line.value)
}

main();
