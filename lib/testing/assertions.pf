// -----------------------------------------------------------------------------
// testing/assertions.pf
//
// Core assertion library.
//
// Assertions are pure functions.
//
// Assertion functions return Option<Failure>.
// Test bodies return TestResult.
//
// -----------------------------------------------------------------------------

export type Failure = {
  message,
  expected,
  actual
}

// Assertion outcome. expected/actual are stringified at assertion time so that
// Failure has uniform field types (all String) — this lets a list of mixed
// assertions (some over ints, some over bools) share one element type.
export type Check = {
  | Pass
  | Fail : failure
}

export type TestResult = {
  failures
}

function failure(message, expected, actual) {
  Fail { Failure { message, __str__(expected), __str__(actual) } };
}

export function assertEqual(expected, actual) {
  if expected == actual then
    Pass
  else
    failure("Expected values to be equal.", expected, actual);
}

export function assertNotEqual(expected, actual) {
  if expected != actual then
    Pass
  else
    failure("Expected values to be different.", "<different value>", actual);
}

export function assertTrue(value) {
  if value then
    Pass
  else
    failure("Expected true.", true, value);
}

export function assertFalse(value) {
  if value then
    failure("Expected false.", false, value)
  else
    Pass;
}

export function assertSome(value) {
  match value with
  | Some _ -> Pass
  | None   -> failure("Expected Some, got None.", "Some", "None");
}

export function assertNone(value) {
  match value with
  | None   -> Pass
  | Some _ -> failure("Expected None, got Some.", "None", "Some");
}

export function check(condition, message) {
  if condition then
    Pass
  else
    failure(message, "true", "false");
}

export function fail(message) {
  failure(message, "", "");
}

export function assertions(assertions) {
  TestResult {
    filter(
      fn assertion =>
        match assertion with
        | Fail _ -> true
        | Pass   -> false,
      assertions
    )
  };
}
