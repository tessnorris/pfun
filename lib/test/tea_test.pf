// -----------------------------------------------------------------------------
// lib/test/tea_test.pf
//
// Tests for lib/tea.pf.
//
// What's testable here:
//   cmdNone, collectHandlers — pure functions, fully testable
//   Handler key naming and function invocation — testable via collectHandlers
//
// What requires integration testing (browser or transpiler):
//   render, attachAll, run, executeCmd — call browser primitives
//   (clearOutput, mountHtml, attachDomHandler, httpPost) that are only
//   available in the transpiled browser runtime, not the interpreter.
//   These are covered by the full-stack example app instead.
//
// Run with:  pfun lib/test/tea_test.pf
// -----------------------------------------------------------------------------

import * from "io";
import * from "../testing/testing";
import * from "../testing/assertions";
import * from "../testing/runner";
import * from "../htmllib";
import * from "../viewlib";
import * from "../tea";

// Re-declare types for match resolution in this module.
type View = {
  | VText      : value
  | VEl        : tag, attrs, children
  | VButton    : label, attrs, onClick
  | VTextInput : name, value, placeholder, onInput
  | VCheckbox  : name, checked, label, onToggle
  | VSelect    : name, choices, selected, onChange
  | VContent   : block
}
type Cmd     = { | CmdNone | Send : msg, onReply, url }
type Handler = { key, handler }
type Attrs   = { id, classes, style }
type Choice  = { value, label }
type Block   = { | Para : content | RawHtml : value | ThematicBreak
               | BulletList : items | OrderedList : items | BlockQuote : content
               | CodeBlock : language, value | Section : heading, content
               | Article : heading, content | Aside : content | Nav : content
               | Form : action, method, fields | Attributed : node, attrs }
type Inline  = { | Text : value | Emph : content | Strong : content
               | InlineCode : value | Link : href, content | HtmlLineBreak }

// ── App types for handler invocation tests ────────────────────────────────────

type Msg = { | Increment | Decrement | Reset }

// ── cmdNone ───────────────────────────────────────────────────────────────────

function testCmdNone() {
  let c = cmdNone();
  match c with
  | CmdNone -> assertions([check(true, "got CmdNone")])
  | Send _  -> assertions([fail("Expected CmdNone")]);
}

function testCmdNoneIsNoCmdVariant() {
  let c = cmdNone();
  match c with
  | CmdNone -> assertions([assertEqual("CmdNone", __str__(c))])
  | Send _  -> assertions([fail("Expected CmdNone")]);
}

// ── collectHandlers — leaf nodes ──────────────────────────────────────────────

function testCollectHandlersVText() {
  assertions([assertEqual(0, length(collectHandlers(vtext("hello"))))]);
}

function testCollectHandlersVContent() {
  assertions([assertEqual(0, length(collectHandlers(vcontent(Para { [Text { "x" }] }))))]);
}

function testCollectHandlersVButton() {
  let hs = collectHandlers(vbutton("Save", Increment));
  assertions([
    assertEqual(1, length(hs)),
    assertEqual("click_Save", head(hs).key)
  ]);
}

function testCollectHandlersVTextInput() {
  let hs = collectHandlers(vinput("q", "", "Search", fn s => s));
  assertions([
    assertEqual(1, length(hs)),
    assertEqual("input_q", head(hs).key)
  ]);
}

function testCollectHandlersVCheckbox() {
  let hs = collectHandlers(vcheckbox("agree", false, "Agree", fn b => b));
  assertions([
    assertEqual(1, length(hs)),
    assertEqual("check_agree", head(hs).key)
  ]);
}

function testCollectHandlersVSelect() {
  let cs = [Choice { "a", "A" }];
  let hs = collectHandlers(vselect("color", cs, "a", fn s => s));
  assertions([
    assertEqual(1, length(hs)),
    assertEqual("change_color", head(hs).key)
  ]);
}

// ── collectHandlers — VEl containers ─────────────────────────────────────────

function testCollectHandlersVElEmpty() {
  assertions([assertEqual(0, length(collectHandlers(vdiv([]))))]);
}

function testCollectHandlersVElWithButton() {
  let hs = collectHandlers(vdiv([vbutton("OK", Increment)]));
  assertions([
    assertEqual(1, length(hs)),
    assertEqual("click_OK", head(hs).key)
  ]);
}

function testCollectHandlersVElMultiple() {
  let v = vdiv([vbutton("A", Increment), vbutton("B", Decrement)]);
  assertions([assertEqual(2, length(collectHandlers(v)))]);
}

function testCollectHandlersNestedEl() {
  let v = vdiv([vspan([vbutton("Deep", Increment)])]);
  let hs = collectHandlers(v);
  assertions([
    assertEqual(1, length(hs)),
    assertEqual("click_Deep", head(hs).key)
  ]);
}

function testCollectHandlersMixedChildren() {
  let v = vdiv([
    vtext("label"),
    vbutton("Submit", Increment),
    vinput("name", "", "ph", fn s => s)
  ]);
  assertions([assertEqual(2, length(collectHandlers(v)))]);
}

function testCollectHandlersDeepNesting() {
  // div > div > span > button — handler found at any depth
  let v = vdiv([vdiv([vspan([vbutton("Nested", Increment)])])]);
  assertions([assertEqual(1, length(collectHandlers(v)))]);
}

// ── Handler key naming ────────────────────────────────────────────────────────

function testHandlerKeyButton() {
  assertions([assertEqual("click_Delete item",
    head(collectHandlers(vbutton("Delete item", Increment))).key)]);
}

function testHandlerKeyInput() {
  assertions([assertEqual("input_user_name",
    head(collectHandlers(vinput("user_name", "", "", fn s => s))).key)]);
}

function testHandlerKeyCheckbox() {
  assertions([assertEqual("check_is_active",
    head(collectHandlers(vcheckbox("is_active", true, "Active", fn b => b))).key)]);
}

function testHandlerKeySelect() {
  let cs = [Choice { "x", "X" }];
  assertions([assertEqual("change_my_select",
    head(collectHandlers(vselect("my_select", cs, "x", fn s => s))).key)]);
}

// ── Handler function invocation ───────────────────────────────────────────────

function testHandlerButtonReturnsMsg() {
  // VButton onClick is returned directly as the message
  let v = vbutton("inc", Increment);
  let h = head(collectHandlers(v));
  let msg = h.handler("click");
  match msg with
  | Increment -> assertions([check(true, "got Increment")])
  | _         -> assertions([fail("Expected Increment")]);
}

function testHandlerInputTransformsString() {
  let v = vinput("q", "", "", fn s => length(s));
  let h = head(collectHandlers(v));
  assertions([assertEqual(5, h.handler("hello"))]);
}

function testHandlerCheckboxReturnsBool() {
  let v = vcheckbox("flag", false, "Label", fn b => b);
  let h = head(collectHandlers(v));
  assertions([
    assertTrue(h.handler(true)),
    assertFalse(h.handler(false))
  ]);
}

function testHandlerSelectTransformsString() {
  let cs = [Choice { "a", "A" }];
  let v = vselect("s", cs, "a", fn s => s + "!");
  let h = head(collectHandlers(v));
  assertions([assertEqual("x!", h.handler("x"))]);
}

function testHandlerButtonMsgIsWrappedAsMsg() {
  // The handler fn wraps onClick value — firing with any input returns onClick
  let v = vbutton("reset", Reset);
  let h = head(collectHandlers(v));
  let msg = h.handler("ignored");
  match msg with
  | Reset -> assertions([check(true, "got Reset")])
  | _     -> assertions([fail("Expected Reset")]);
}

// ── Multiple handlers from complex view ───────────────────────────────────────

function testHandlerOrderPreserved() {
  // Handlers come out in document order (left-to-right, depth-first)
  let v = vdiv([
    vbutton("first", Increment),
    vdiv([vbutton("second", Decrement)]),
    vbutton("third", Reset)
  ]);
  let hs = collectHandlers(v);
  assertions([
    assertEqual(3, length(hs)),
    assertEqual("click_first",  head(hs).key),
    assertEqual("click_second", head(tail(hs)).key),
    assertEqual("click_third",  head(tail(tail(hs))).key)
  ]);
}

function testAllInteractiveNodesCollected() {
  // A view with one of each interactive node type
  let cs = [Choice { "a", "A" }];
  let v = vdiv([
    vbutton("btn", Increment),
    vinput("inp", "", "ph", fn s => s),
    vcheckbox("chk", false, "Label", fn b => b),
    vselect("sel", cs, "a", fn s => s)
  ]);
  assertions([assertEqual(4, length(collectHandlers(v)))]);
}

// ── Suites ────────────────────────────────────────────────────────────────────

let cmdSuite = suite("Cmd", [
  test("cmdNone produces CmdNone",          testCmdNone),
  test("cmdNone stringifies as CmdNone",    testCmdNoneIsNoCmdVariant)
]);

let leafSuite = suite("collectHandlers — leaf nodes", [
  test("VText: no handlers",          testCollectHandlersVText),
  test("VContent: no handlers",       testCollectHandlersVContent),
  test("VButton: click handler",      testCollectHandlersVButton),
  test("VTextInput: input handler",   testCollectHandlersVTextInput),
  test("VCheckbox: check handler",    testCollectHandlersVCheckbox),
  test("VSelect: change handler",     testCollectHandlersVSelect)
]);

let containerSuite = suite("collectHandlers — containers", [
  test("empty VEl: no handlers",          testCollectHandlersVElEmpty),
  test("VEl with one button",             testCollectHandlersVElWithButton),
  test("VEl with two buttons",            testCollectHandlersVElMultiple),
  test("nested VEl: handler found",       testCollectHandlersNestedEl),
  test("mixed children: events only",     testCollectHandlersMixedChildren),
  test("deep nesting: still found",       testCollectHandlersDeepNesting)
]);

let keySuite = suite("Handler key naming", [
  test("button: click_<label>",   testHandlerKeyButton),
  test("input: input_<name>",     testHandlerKeyInput),
  test("checkbox: check_<name>",  testHandlerKeyCheckbox),
  test("select: change_<name>",   testHandlerKeySelect)
]);

let invokeSuite = suite("Handler function invocation", [
  test("button handler returns onClick msg",     testHandlerButtonReturnsMsg),
  test("input handler transforms string",        testHandlerInputTransformsString),
  test("checkbox handler returns bool",          testHandlerCheckboxReturnsBool),
  test("select handler transforms string",       testHandlerSelectTransformsString),
  test("button msg identity (Reset)",            testHandlerButtonMsgIsWrappedAsMsg)
]);

let complexSuite = suite("Complex view trees", [
  test("handler order is document order",          testHandlerOrderPreserved),
  test("all interactive node types collected",     testAllInteractiveNodesCollected)
]);

runSuites([cmdSuite, leafSuite, containerSuite, keySuite, invokeSuite, complexSuite]);
