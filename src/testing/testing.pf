// -----------------------------------------------------------------------------
// testing/testing.pf
//
// Core test model.
//
// Tests, suites and fixtures are ordinary immutable values.
//
// The runner interprets these values.
// -----------------------------------------------------------------------------

export type Fixture = {
  before,
  after
}

export type Test = {
  name,
  fixture,
  body
}

export type Suite = {
  name,
  tests
}

proc noOp() {}

export let noFixture =
  Fixture {
    noOp,
    noOp
  };

export function fixture(before, after) {
  Fixture {
    before,
    after
  };
}

export function test(name, body) {
  Test {
    name,
    noFixture,
    body
  };
}

export function testUsing(name, fixture, body) {
  Test {
    name,
    fixture,
    body
  };
}

export function suite(name, tests) {
  Suite {
    name,
    tests
  };
}

// suite with no initial tests — for use with the pipe/addTest pattern:
//   let s = emptySuite("My suite")
//     |> addTest(test("case 1", testFn1))
//     |> addTest(test("case 2", testFn2));
export function emptySuite(name) {
  Suite { name, [] };
}

// addTest: append a test to a suite, returning the updated suite.
// Designed for use with the pipe operator:
//   let s = emptySuite("My suite")
//     |> addTest(test("case 1", testFn1))
//     |> addTest(test("case 2", testFn2));
export function addTest(t, s) {
  Suite { s.name, s.tests + [t] };
}

// composeFixtures requires anonymous procedures (to close over `first` and
// `second` while performing side effects). Pfun has no anonymous proc syntax
// yet — `fn` lambdas are pure and cannot run before/after side effects. Until
// anonymous procs land, compose fixtures manually with a named proc.
//
// export function composeFixtures(first, second) {
//   Fixture {
//     proc() { first.before(); second.before(); },
//     proc() { second.after(); first.after(); }
//   };
// }

export function withFixture(test, fixture) {
  Test {
    test.name,
    fixture,
    test.body
  };
}
