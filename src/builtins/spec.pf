function fileExports() {
	let handle = TY.tNamed("FileHandle", []);
	let mode = TY.tNamed("FileMode", []);
	let buffer = TY.tNamed("Buffer", []);
	let bufferMode = TY.tNamed("BufferMode", []);
	let charRead = TY.tNamed(
		"ReadResult",
		[TY.tChar(), nativeErrorT()]
	);
	let lineRead = TY.tNamed(
		"ReadResult",
		[TY.tStr(), nativeErrorT()]
	);
	let byteRead = TY.tNamed(
		"ReadResult",
		[TY.tByte(), nativeErrorT()]
	);
	let bytesRead = TY.tNamed(
		"ReadResult",
		[listOf(TY.tByte()), nativeErrorT()]
	);

	[
		nodeProc(
			"readFile",
			sch(
				[],
				proc1(
					TY.tStr(),
					nativeResult(TY.tStr()),
					false
				)
			),
			"$readFile"
		),
		nodeProc(
			"writeFile",
			sch(
				[],
				proc2(
					TY.tStr(),
					TY.tStr(),
					nativeResult(TY.tUnit()),
					false
				)
			),
			"$writeFile"
		),
		nodeProc(
			"fileExists",
			sch(
				[],
				proc1(
					TY.tStr(),
					nativeResult(TY.tBool()),
					false
				)
			),
			"$fileExists"
		),
		nodeProc(
			"mkdirP",
			sch(
				[],
				proc1(
					TY.tStr(),
					nativeResult(TY.tUnit()),
					false
				)
			),
			"$mkdirP"
		),
		nodeProc(
			"removeFile",
			sch(
				[],
				proc1(
					TY.tStr(),
					nativeResult(TY.tUnit()),
					false
				)
			),
			"$removeFile"
		),
		nodeProc(
			"fileOpen",
			sch(
				[],
				proc2(
					TY.tStr(),
					mode,
					nativeResult(handle),
					false
				)
			),
			"$fileOpen"
		),
		nodeProc(
			"fileClose",
			sch(
				[],
				proc1(
					handle,
					nativeResult(TY.tUnit()),
					false
				)
			),
			"$fileClose"
		),
		nodeProc(
			"readChar",
			sch([], proc1(handle, charRead, false)),
			"$readChar"
		),
		nodeProc(
			"readLine",
			sch([], proc1(handle, lineRead, false)),
			"$readLine"
		),
		nodeProc(
			"readByte",
			sch([], proc1(handle, byteRead, false)),
			"$readByte"
		),
		nodeProc(
			"readBytes",
			sch(
				[],
				proc2(
					handle,
					TY.tInt(),
					bytesRead,
					false
				)
			),
			"$readBytes"
		),
		nodeProc(
			"writeChar",
			sch(
				[],
				proc2(
					handle,
					TY.tChar(),
					nativeResult(TY.tUnit()),
					false
				)
			),
			"$writeChar"
		),
		nodeProc(
			"writeLine",
			sch(
				[],
				proc2(
					handle,
					TY.tStr(),
					nativeResult(TY.tUnit()),
					false
				)
			),
			"$writeLine"
		),
		nodeProc(
			"writeByte",
			sch(
				[],
				proc2(
					handle,
					TY.tByte(),
					nativeResult(TY.tUnit()),
					false
				)
			),
			"$writeByte"
		),
		nodeProc(
			"writeBytes",
			sch(
				[],
				proc2(
					handle,
					listOf(TY.tByte()),
					nativeResult(TY.tUnit()),
					false
				)
			),
			"$writeBytes"
		),
		nodeProc(
			"readBuffer",
			sch(
				[],
				proc3(
					handle,
					TY.tInt(),
					bufferMode,
					nativeResult(buffer),
					false
				)
			),
			"$readBuffer"
		),
		nodeProc(
			"writeBuffer",
			sch(
				[],
				proc2(
					handle,
					buffer,
					nativeResult(TY.tUnit()),
					false
				)
			),
			"$writeBuffer"
		),
		nodeProc(
			"makeBuffer",
			sch(
				[],
				proc1(bufferMode, buffer, false)
			),
			"$makeBuffer"
		),
		nodeProc(
			"makeStringBuffer",
			sch([], proc0(buffer, false)),
			"$makeStringBuffer"
		),
		nodeProc(
			"appendBuffer",
			sch(
				[],
				proc2(buffer, TY.tByte(), TY.tUnit(), false)
			),
			"$appendBuffer"
		),
		nodeProc(
			"appendChar",
			sch(
				[],
				proc2(buffer, TY.tChar(), TY.tUnit(), false)
			),
			"$appendChar"
		),
		nodeProc(
			"appendString",
			sch(
				[],
				proc2(buffer, TY.tStr(), TY.tUnit(), false)
			),
			"$appendString"
		),
		nodePure(
			"bufferLength",
			sch([], fn1(buffer, TY.tInt())),
			"$bufferLength"
		),
		nodePure(
			"bufferToBytes",
			sch([], fn1(buffer, listOf(TY.tByte()))),
			"$bufferToBytes"
		),
		nodePure(
			"bufferToString",
			sch([], fn1(buffer, TY.tStr())),
			"$bufferToString"
		)
	]
}

