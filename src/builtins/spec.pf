function mathExports() {
	[
		pure("pi", sch([], fn1(TY.tUnit(), TY.tFloat())), "$pi"),
		pure("e", sch([], fn1(TY.tUnit(), TY.tFloat())), "$e"),
		pure("tau", sch([], fn1(TY.tUnit(), TY.tFloat())), "$tau"),
		pure("sqrt", sch([], fn1(TY.tFloat(), TY.tFloat())), "$sqrt"),
		pure("pow", sch([], fn2(TY.tFloat(), TY.tFloat(), TY.tFloat())), "$pow"),
		pure("abs", sch([], fn1(TY.tInt(), TY.tInt())), "$absInt"),
		pure("min", sch([], fn2(TY.tInt(), TY.tInt(), TY.tInt())), "$minInt"),
		pure("max", sch([], fn2(TY.tInt(), TY.tInt(), TY.tInt())), "$maxInt")
