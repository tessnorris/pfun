import * from "io";

// List literal
let nums = [1, 2, 3, 4, 5];
println(nums);

// length, head, tail
println(length(nums));
println(head(nums));
println(tail(nums));

// map
let doubled = map(fn n => n * 2, nums);
println(doubled);

// filter
let evens = filter(fn n => n % 2 == 0, nums);
println(evens);

// reduce — takes a named binary function (not curried)
function add2(acc, n) { return acc + n; }
let total = reduce(add2, 0, nums);
println(total);

// reverse
println(reverse(nums));

// cons
let extended = cons(0, nums);
println(extended);

// take
println(take(3, nums));

// nth (list, index)
println(nth(nums, 2));

// List comprehension
let squares = [n * n for n <- nums];
println(squares);

// Comprehension with guard
let odd_squares = [n * n for n <- nums where n % 2 != 0];
println(odd_squares);

// Nested comprehension
let xs2 = [1, 2];
let ys2 = [3, 4];
let pairs = [x + y for x <- xs2 for y <- ys2];
println(pairs);

// join — Pfun's join(list, separator)
println(join(["a", "b", "c"], ", "));
