import * from "io";

// Simple function
function double(n) {
  return n * 2;
}
println(double(5));
println(double(-3));

// Function with if/else
function abs_val(n) {
  if n >= 0 then return n;
  else return -n;
}
println(abs_val(7));
println(abs_val(-4));

// Ternary expression
let sign = fn n => n > 0 ? "positive" : (n < 0 ? "negative" : "zero");
println(sign(5));
println(sign(-3));
println(sign(0));

// Tail-recursive function (treated as plain recursion in v1)
function factorial(n) {
  if n <= 1 then return 1;
  else return n * factorial(n - 1);
}
println(factorial(5));
println(factorial(10));

// Mutual recursion via let-bound lambdas
let is_even = fn n => n == 0 ? true  : n < 0 ? false : is_odd(n - 1);
let is_odd  = fn n => n == 0 ? false : n < 0 ? false : is_even(n - 1);
println(is_even(4));
println(is_odd(7));

// var / mutation in a procedure
proc increment_and_print() {
  var counter = 0;
  counter = counter + 1;
  counter = counter + 1;
  println(counter);
}
increment_and_print();
