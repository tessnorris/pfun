// test/runner.pf — small bootstrap-safe test runner primitives.
//
// This runner stores pure functions as values. It never stores procs, so it is
// compatible with V2's second-class proc rule. Generated harnesses may choose to
// call these helpers or inline equivalent code.

import * as A from "./assertions";
import * as ListX from "../data/listx";
import * as StrX from "../data/strx";

export type TestCase = { name, run }
export type Suite = { name, tests }
export type TestReport = { suite, name, result }
export type RunSummary = { reports, passed, failed }

export function test(name, run) {
	TestCase { name, run }
}

export function suite(name, tests) {
	Suite { name, tests }
}

export function report(suiteName, testName, result) {
	TestReport { suiteName, testName, result }
}

function runTest(suiteName, t) {
	report(suiteName, t.name, t.run())
}

export function runSuite(s) {
	map(fn t => runTest(s.name, t), s.tests)
}

export function runSuites(suites) {
	let reports = ListX.concat(map(runSuite, suites));
	let passed = ListX.countWhere(fn r => A.resultOk(r.result), reports);
	let failed = length(reports) - passed;
	RunSummary { reports, passed, failed }
}

export function summaryOk(summary) {
	summary.failed == 0
}

function reportLine(r) {
	if A.resultOk(r.result) then {
		"PASS " ++ r.suite ++ " / " ++ r.name
	} else {
		let msgs = A.resultMessages(r.result);
		"FAIL " ++ r.suite ++ " / " ++ r.name ++ "\n" ++ StrX.indent(2, StrX.joinLines(msgs))
	}
}

export function renderReport(r) {
	reportLine(r)
}

export function renderSummary(summary) {
	let body = StrX.joinLines(map(renderReport, summary.reports));
	let totals = __str__(summary.passed) ++ " passed, " ++ __str__(summary.failed) ++ " failed";
	if length(body) == 0 then { totals } else { body ++ "\n" ++ totals }
}

export proc printSummary(summary) {
	println(renderSummary(summary));
}

export proc exitForSummary(summary) {
	if summary.failed == 0 then { exit(0); } else { exit(1); }
}
