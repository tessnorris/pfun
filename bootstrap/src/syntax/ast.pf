// ── common AST queries used by the parser and later passes ─────────────────

export function exprId(expr) {
	match expr with
	| EInt e -> e.id
	| EFloat e -> e.id
	| EBool e -> e.id
	| EStr e -> e.id
	| EChar e -> e.id
	| EByte e -> e.id
	| EVar e -> e.id
	| EUnary e -> e.id
	| EBinary e -> e.id
	| EIf e -> e.id
	| ECall e -> e.id
	| ELambda e -> e.id
	| EBlock e -> e.id
	| EList e -> e.id
	| EComp e -> e.id
	| ERecord e -> e.id
	| EField e -> e.id
	| EIndex e -> e.id
	| EMatch e -> e.id
	| EDict e -> e.id
	| EArray e -> e.id
	| EAwait e -> e.id
	| EFmt e -> e.id
}

export function exprSpan(expr) {
	match expr with
	| EInt e -> e.span
	| EFloat e -> e.span
	| EBool e -> e.span
	| EStr e -> e.span
	| EChar e -> e.span
	| EByte e -> e.span
	| EVar e -> e.span
	| EUnary e -> e.span
	| EBinary e -> e.span
	| EIf e -> e.span
	| ECall e -> e.span
	| ELambda e -> e.span
	| EBlock e -> e.span
	| EList e -> e.span
	| EComp e -> e.span
	| ERecord e -> e.span
	| EField e -> e.span
	| EIndex e -> e.span
	| EMatch e -> e.span
	| EDict e -> e.span
	| EArray e -> e.span
	| EAwait e -> e.span
	| EFmt e -> e.span
}

export function stmtSpan(stmt) {
	match stmt with
	| SLet s -> s.span
	| SVar s -> s.span
	| SAssign s -> s.span
	| SIndexAssign s -> s.span
	| SFun s -> s.span
	| SType s -> s.span
	| SExpr s -> s.span
	| SReturn s -> s.span
	| SIf s -> s.span
	| SWhile s -> s.span
	| SImport s -> s.span
	| SExport s -> s.span
	| SExtern s -> s.span
}

export function spanJoin(a, b) {
	// `a` and `b` are end-exclusive spans. The parser only joins spans where
	// `a.start` is before `b.end`, so no ordering comparison is needed here.
	T.mkSpan(a.start, b.end)
}

export function assignVarName(expr) {
	match expr with
	| EVar e -> Some { e.name }
	| _ -> None
}

export function assignIndexParts(expr) {
	match expr with
	| EIndex e -> Some { Pair { e.object, e.index } }
	| _ -> None
}

export function isNoArgVariantPattern(pattern) {
	match pattern with
	| PVariant p -> {
		match p.bind with
		| None -> true
		| Some _ -> false
	}
	| _ -> false
}

// ── private concrete signature anchors ─────────────────────────────────────
//
// Pfun is monomorphic by default. These function-value groups constrain each
// exported smart constructor/query to its complete nominal signature without
// calling it at module initialization. The declaration witness above grounds
// the data schemas; these anchors ground the independently inferred functions.

let astSigPos = T.mkPos(1, 1, 0);
let astSigSpan = T.mkSpan(astSigPos, astSigPos);
let astSigExpr = EInt { 0, 0, astSigSpan };
let astSigStmt = SExpr { 0, astSigExpr, astSigSpan };
let astSigExprs = [astSigExpr];
let astSigStmts = [astSigStmt];
let astSigStrings = [""];
let astSigMode = StrictList;
let astSigField = Field { Some { "field" }, astSigExpr };
let astSigFields = [astSigField];
let astSigGen = GenClause { "item", astSigExpr };
let astSigGens = [astSigGen];
let astSigEntry = DictEntry { astSigExpr, astSigExpr };
let astSigEntries = [astSigEntry];
let astSigPattern = PWild;
let astSigArm = MatchArm {
	astSigPattern,
	Some { astSigExpr },
	astSigExpr
};
let astSigArms = [astSigArm];
let astSigFmtPart = FmtLit { "" };
let astSigFmts = [astSigFmtPart];
let astSigFieldDecl = FieldDecl { "field", false };
let astSigTypeDecl = RecordDecl {
	"R",
	[astSigFieldDecl]
};
let astSigTypeExpr = TyName { "Int", [] };
let astSigTypeExprs = [astSigTypeExpr];
let astSigImportSpec = IStar;
let astSigFnKind = PureFn { false, false };
let astSigExternDecl = ExternDecl {
	ExternFunction,
	"nativeThing",
	[
		TypedParam {
			"x",
			astSigTypeExpr
		}
	],
	astSigTypeExpr,
	Some { "node" }
};

function astSigIntIntSpanExpr(id, n, span) {
	let ids = [0, id];
	let nums = [0, n];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigIntIntSpanExprFns = [
	astSigIntIntSpanExpr,
	eInt
];

function astSigIntStrSpanExpr(id, text, span) {
	let ids = [0, id];
	let texts = ["", text];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigIntStrSpanExprFns = [
	astSigIntStrSpanExpr,
	eFloat,
	eStr,
	eVar
];

function astSigIntBoolSpanExpr(id, value, span) {
	let ids = [0, id];
	let values = [false, value];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigIntBoolSpanExprFns = [
	astSigIntBoolSpanExpr,
	eBool
];

function astSigIntCharSpanExpr(id, value, span) {
	let ids = [0, id];
	let values = ["x", value];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigIntCharSpanExprFns = [
	astSigIntCharSpanExpr,
	eChar
];

function astSigIntByteSpanExpr(id, value, span) {
	let ids = [0, id];
	let values = [0, value];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigIntByteSpanExprFns = [
	astSigIntByteSpanExpr,
	eByte
];

function astSigUnary(id, op, operand, span) {
	let ids = [0, id];
	let ops = ["", op];
	let operands = [astSigExpr, operand];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigUnaryFns = [
	astSigUnary,
	eUnary
];

function astSigBinary(id, op, lhs, rhs, span) {
	let ids = [0, id];
	let ops = ["", op];
	let lefts = [astSigExpr, lhs];
	let rights = [astSigExpr, rhs];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigBinaryFns = [
	astSigBinary,
	eBinary
];

function astSigIf(id, cond, thenE, elseE, span) {
	let ids = [0, id];
	let conds = [astSigExpr, cond];
	let thens = [astSigExpr, thenE];
	let elses = [astSigExpr, elseE];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigIfFns = [
	astSigIf,
	eIf
];

function astSigCall(id, callee, args, span) {
	let ids = [0, id];
	let callees = [astSigExpr, callee];
	let argLists = [astSigExprs, args];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigCallFns = [
	astSigCall,
	eCall
];

function astSigLambda(id, params, body, span) {
	let ids = [0, id];
	let paramLists = [astSigStrings, params];
	let bodies = [astSigExpr, body];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigLambdaFns = [
	astSigLambda,
	eLambda
];

function astSigBlock(id, stmts, span) {
	let ids = [0, id];
	let stmtLists = [astSigStmts, stmts];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigBlockFns = [
	astSigBlock,
	eBlock
];

function astSigList(id, elems, mode, span) {
	let ids = [0, id];
	let elemLists = [astSigExprs, elems];
	let modes = [astSigMode, mode];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigListFns = [
	astSigList,
	eList
];

function astSigComp(id, body, gens, guard, mode, span) {
	let ids = [0, id];
	let bodies = [astSigExpr, body];
	let genLists = [astSigGens, gens];
	let guards = [Some { astSigExpr }, guard];
	let modes = [astSigMode, mode];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigCompFns = [
	astSigComp,
	eComp
];

function astSigRecord(id, tname, fields, span) {
	let ids = [0, id];
	let names = ["", tname];
	let fieldLists = [astSigFields, fields];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigRecordFns = [
	astSigRecord,
	eRecord
];

function astSigFieldAccess(id, object, fname, span) {
	let ids = [0, id];
	let objects = [astSigExpr, object];
	let names = ["", fname];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigFieldAccessFns = [
	astSigFieldAccess,
	eField
];

function astSigIndex(id, object, index, span) {
	let ids = [0, id];
	let objects = [astSigExpr, object];
	let indexes = [astSigExpr, index];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigIndexFns = [
	astSigIndex,
	eIndex
];

function astSigMatch(id, subject, arms, span) {
	let ids = [0, id];
	let subjects = [astSigExpr, subject];
	let armLists = [astSigArms, arms];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigMatchFns = [
	astSigMatch,
	eMatch
];

function astSigDict(id, entries, span) {
	let ids = [0, id];
	let entryLists = [astSigEntries, entries];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigDictFns = [
	astSigDict,
	eDict
];

function astSigArray(id, elems, span) {
	let ids = [0, id];
	let elemLists = [astSigExprs, elems];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigArrayFns = [
	astSigArray,
	eArray
];

function astSigAwait(id, value, span) {
	let ids = [0, id];
	let values = [astSigExpr, value];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigAwaitFns = [
	astSigAwait,
	eAwait
];

function astSigFmt(id, parts, span) {
	let ids = [0, id];
	let partLists = [astSigFmts, parts];
	let spans = [astSigSpan, span];
	astSigExpr
}
let astSigFmtFns = [
	astSigFmt,
	eFmt
];

function astSigTyName(name, args) {
	let names = ["", name];
	let argLists = [astSigTypeExprs, args];
	astSigTypeExpr
}
let astSigTyNameFns = [
	astSigTyName,
	tyName
