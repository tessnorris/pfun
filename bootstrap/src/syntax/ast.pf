// syntax/ast.pf — Phase 4 AST model for the bootstrap compiler.

import * as T from "./token";

//
// The AST is syntax only. It carries stable node ids and source spans, but no
// inferred types, name-resolution facts, purity facts, exhaustiveness data, or
// emission metadata. Later passes keep analysis results in side tables keyed by
// node id.

// ── expressions ─────────────────────────────────────────────────────────────

export type ListMode = {
	| StrictList
	| LazyList
}

export type Field = { fname, value }

export type GenClause = { gvar, source }

export type DictEntry = { key, value }

export type PatElem = {
	| PeBind: pname
	| PeWild
}

export type Pattern = {
	| PWild
	| PVariant: vname, bind
	| PList: elems, rest
}

export type MatchArm = { pattern, guard, body }

export type FmtPart = {
	| FmtLit: s
	| FmtExpr: e
}

export type Expr = {
	| EInt: id, n, span
	| EFloat: id, text, span
	| EBool: id, b, span
	| EStr: id, s, span
	| EChar: id, c, span
	| EByte: id, b, span

	| EVar: id, name, span

	| EUnary: id, op, operand, span
	| EBinary: id, op, lhs, rhs, span
	| EIf: id, cond, thenE, elseE, span

	| ECall: id, callee, args, span
	| ELambda: id, params, body, span
	| EBlock: id, stmts, span

	| EList: id, elems, mode, span
	| EComp: id, body, gens, guard, mode, span
	| ERecord: id, tname, fields, span

	| EField: id, object, fname, span
	| EIndex: id, object, index, span
	| EMatch: id, subject, arms, span

	| EDict: id, entries, span
	| EArray: id, elems, span
	| EAwait: id, value, span
	| EFmt: id, parts, span
}

// ── statements/declarations ────────────────────────────────────────────────

// `memo` is a keyword, so using it as a field name makes `kind.memo`
// unparseable. Keep the semantic meaning but expose the field as `isMemo`.
export type FnKind = {
	| PureFn: isMemo, isGeneric
	| ProcFn: isAsync, isGeneric
}

export type FieldDecl = { fname, isGeneric }

export type VariantDecl = { vname, fields }

export type TypeDecl = {
	| RecordDecl: tname, fields
	| UnionDecl: tname, variants
}

export type ImportName = { name, alias }

export type ImportSpec = {
	| INames: names
	| INamespace: alias
	| IStar
}

export type TypeExpr = {
	| TyName: name, args
	| TyFun: params, ret
}

export type ExternKind = {
	| ExternFunction
	| ExternProc: isAsync
}

export type TypedParam = { name, typeExpr }

export type ExternDecl = { kind, name, params, ret, platform }

export type Stmt = {
	| SLet: id, name, init, span
	| SVar: id, name, init, span
	| SAssign: id, name, value, span
	| SIndexAssign: id, object, index, value, span
	| SFun: id, name, params, body, kind, span
	| SType: id, decl, isOpaque, span
	| SExpr: id, expr, span
	| SReturn: id, value, span
	| SIf: id, cond, thenS, elseS, span
	| SWhile: id, cond, body, span
	| SImport: id, spec, rawPath, span
	| SExport: id, inner, span
	| SExtern: id, decl, span
}

export type Module = { path, stmts, nextId }

// Pin the complete non-generic AST schema before the exported constructor
// surface is inferred. The AST is nominal and monomorphic; genericity belongs
// in compiler functions that transform it, not in its syntax fields.
function astTypeWitness() {
	let p = T.mkPos(1, 1, 0);
	let sp = T.mkSpan(p, p);
	let baseExpr = EInt { 0, 0, sp };
	let baseStmt = SExpr { 0, baseExpr, sp };
	let patElem = PeBind { "p" };
	let pattern = PVariant { "V", Some { "value" } };
	let field = Field { Some { "field" }, baseExpr };
	let gen = GenClause { "item", baseExpr };
	let entry = DictEntry { baseExpr, baseExpr };
	let arm = MatchArm { pattern, Some { baseExpr }, baseExpr };
	let fmt = FmtLit { "" };
	let kind = PureFn { false, false };
	let fieldDecl = FieldDecl { "field", false };
	let variantDecl = VariantDecl { "V", [fieldDecl] };
	let typeDecl = RecordDecl { "R", [fieldDecl] };
	let importName = ImportName { "name", Some { "alias" } };
	let importSpec = INames { [importName] };
	let typeExpr = TyName { "Int", [] };
	let typedParam = TypedParam { "x", typeExpr };
	let externDecl = ExternDecl {
		ExternFunction,
		"nativeThing",
		[typedParam],
		typeExpr,
		Some { "node" }
	};

	let supporting = [
		PeBind { "p" },
		PeWild
	];
	let patterns = [
		PWild,
		pattern,
		PList { [patElem], Some { patElem } }
	];
	let formatParts = [fmt, FmtExpr { baseExpr }];
	let expressions = [
		baseExpr,
		EFloat { 0, "0.0", sp },
		EBool { 0, false, sp },
		EStr { 0, "", sp },
		EChar { 0, "x", sp },
		EByte { 0, 0, sp },
		EVar { 0, "x", sp },
		EUnary { 0, "-", baseExpr, sp },
		EBinary { 0, "+", baseExpr, baseExpr, sp },
		EIf { 0, baseExpr, baseExpr, baseExpr, sp },
		ECall { 0, baseExpr, [baseExpr], sp },
		ELambda { 0, ["x"], baseExpr, sp },
		EBlock { 0, [baseStmt], sp },
		EList { 0, [baseExpr], StrictList, sp },
		EComp { 0, baseExpr, [gen], Some { baseExpr }, LazyList, sp },
		ERecord { 0, "R", [field], sp },
		EField { 0, baseExpr, "field", sp },
		EIndex { 0, baseExpr, baseExpr, sp },
		EMatch { 0, baseExpr, [arm], sp },
		EDict { 0, [entry], sp },
		EArray { 0, [baseExpr], sp },
		EAwait { 0, baseExpr, sp },
		EFmt { 0, formatParts, sp }
	];
	let fnKinds = [kind, ProcFn { false, false }];
	let typeDecls = [
		typeDecl,
		UnionDecl { "U", [variantDecl] }
	];
	let importSpecs = [
		importSpec,
		INamespace { "N" },
		IStar
	];
	let typeExprs = [
		typeExpr,
		TyFun { [typeExpr], typeExpr }
	];
	let externKinds = [ExternFunction, ExternProc { false }];
	let statements = [
		SLet { 0, "x", baseExpr, sp },
		SVar { 0, "x", baseExpr, sp },
		SAssign { 0, "x", baseExpr, sp },
		SIndexAssign { 0, baseExpr, baseExpr, baseExpr, sp },
		SFun { 0, "f", ["x"], [baseStmt], kind, sp },
		SType { 0, typeDecl, false, sp },
		baseStmt,
		SReturn { 0, Some { baseExpr }, sp },
		SIf { 0, baseExpr, [baseStmt], Some { [baseStmt] }, sp },
		SWhile { 0, baseExpr, [baseStmt], sp },
		SImport { 0, importSpec, "./dep", sp },
		SExport { 0, baseStmt, sp },
		SExtern { 0, externDecl, sp }
	];

	Module { "witness.pf", statements, 1 }
}

// ── smart constructors: supporting nodes ───────────────────────────────────

export function strictListMode() { StrictList }
export function lazyListMode() { LazyList }

export function mkField(fname, value) {
	Field { fname, value }
}

export function mkGenClause(gvar, source) {
	GenClause { gvar, source }
}

export function mkDictEntry(key, value) {
	DictEntry { key, value }
}

export function peBind(pname) {
	PeBind { pname }
}

export function peWild() {
	PeWild
}

export function pWild() {
	PWild
}

export function pVariant(vname, bind) {
	PVariant { vname, bind }
}

export function pList(elems, rest) {
	PList { elems, rest }
}

export function mkMatchArm(pattern, guard, body) {
	MatchArm { pattern, guard, body }
}

export function fmtLit(s) {
	FmtLit { s }
}

export function fmtExpr(e) {
	FmtExpr { e }
}

