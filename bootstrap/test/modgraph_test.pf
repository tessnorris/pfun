// test/graph/modgraph_test.pf — tests for graph/modgraph.pf.

import * as Assert from "testing/assertions";
import * as H from "./check_helpers";
import * as ModGraph from "../src/graph/modgraph";
import * as A from "../src/syntax/ast";
import * as T from "../src/syntax/token";
import * as Compat from "../src/compat";


function span() {
	let p = T.mkPos(1, 1, 0);
	T.pointSpan(p)
}

function env() {
	ModGraph.mkSearchEnv("bootstrap/src/stdlib", ".", ["io", "file", "math", "db/postgresql"])
}

function emptyAst(path) {
	A.mkModule(path, [], 1)
}

function edge(rawPath, resolved) {
	ModGraph.mkImportEdge(A.iStar(), rawPath, resolved, span())
}

function raw(path, edges) {
	ModGraph.mkRawModule(path, emptyAst(path), edges)
}

function resolvedString(rawPath, fromDir) {
	match ModGraph.resolveImport(rawPath, fromDir, env()) with
	| ResolveOk ok -> ModGraph.resolvedPathToStr(ok.resolved)
	| ResolveErr _ -> "<err>"
}

function resolveFails(rawPath) {
	let noLibEnv = ModGraph.mkSearchEnv("", "", ["io"]);
	match ModGraph.resolveImport(rawPath, ".", noLibEnv) with
	| ResolveOk _ -> false
	| ResolveErr _ -> true
}

function firstTopoPath(mods) {
	match Compat.listAt(mods, 0) with
	| None -> "<missing>"
	| Some m -> m.value.path
}

function secondTopoPath(mods) {
	match Compat.listAt(mods, 1) with
	| None -> "<missing>"
	| Some m -> m.value.path
}

function parseModule(path, source) {
	match H.parseSource(path, source) with
	| SourceOk ok -> ok.module
	| SourceErr _ -> emptyAst(path)
}

function edgeCount(path, source) {
	let module = parseModule(path, source);
	match ModGraph.edgesOf(module, env()) with
	| EdgesOk ok -> length(ok.edges)
	| EdgesErr _ -> -1
}

function firstEdgeResolved(path, source) {
	let module = parseModule(path, source);
	match ModGraph.edgesOf(module, env()) with
	| EdgesErr _ -> "<err>"
	| EdgesOk ok -> {
		match Compat.listAt(ok.edges, 0) with
		| None -> "<missing>"
		| Some e -> ModGraph.resolvedPathToStr(e.value.resolved)
	}
}

//![suite("graph/modgraph")]
//![test("resolves relative builtin and library imports")]
function testResolveImportKinds() {
	Assert.assertions([
		Assert.assertEqual(
			"src/lib/foo.pf",
			resolvedString("./lib/foo", "src")
		),
		Assert.assertEqual(
			"src/common/util.pf",
			resolvedString(
				"../common/util",
				"src/app"
			)
		),
		Assert.assertEqual(
			"$builtin/io",
			resolvedString("io", "src")
		),
		Assert.assertEqual(
			"bootstrap/src/stdlib/widgets.pf",
			resolvedString("widgets", "src")
		),
		Assert.assertEqual(
			"bootstrap/src/testing/assertions.pf",
			resolvedString(
				"testing/assertions",
				"src"
			)
		),
		Assert.assertEqual(
			"bootstrap/src/browser/tea.pf",
			resolvedString("browser/tea", "src")
		),
		Assert.assertTrue(resolveFails("unknown"))
	])
}

//![test("normalizes paths and directories")]
function testNormalizeAndDir() {
	Assert.assertions([
		Assert.assertEqual("src/app/main.pf", ModGraph.normalizePath("./src/ui/../app/main.pf")),
		Assert.assertEqual("src/app", ModGraph.dirOf("src/app/main.pf")),
		Assert.assertEqual(".", ModGraph.dirOf("main.pf")),
		Assert.assertEqual("/src", ModGraph.dirOf("/src/main.pf"))
	])
}

//![test("extracts import edges from parsed modules")]
function testEdgesOfParsedModule() {
	let source = "import { foo as bar, baz } from \"./dep\"; import * as IO from \"io\"; import * from \"math\"; let x = 1;";
	Assert.assertions([
		Assert.assertEqual(3, edgeCount("src/app.pf", source)),
		Assert.assertEqual("src/dep.pf", firstEdgeResolved("src/app.pf", source))
	])
}

//![test("toposort orders dependencies before dependents")]
function testTopoDependencyOrder() {
	let dep = raw("src/dep.pf", []);
	let app = raw("src/app.pf", [edge("./dep", ModGraph.userPath("src/dep.pf"))]);
	match ModGraph.toposort([app, dep]) with
	| TopoErr e -> Assert.assertions([Assert.fail("Expected topo success, got " ++ __str__(length(e.diags)) ++ " diagnostics.")])
	| TopoOk ok -> Assert.assertions([
		Assert.assertEqual(2, length(ok.modules)),
		Assert.assertEqual("src/dep.pf", firstTopoPath(ok.modules)),
		Assert.assertEqual("src/app.pf", secondTopoPath(ok.modules))
	])
}

//![test("toposort ignores builtin imports")]
function testTopoIgnoresBuiltins() {
	let app = raw("src/app.pf", [edge("io", ModGraph.builtinPath("io"))]);
	match ModGraph.toposort([app]) with
	| TopoErr e -> Assert.assertions([Assert.fail("Expected builtin import to be ignored by topo, got " ++ __str__(length(e.diags)) ++ " diagnostics.")])
	| TopoOk ok -> Assert.assertions([
		Assert.assertEqual(1, length(ok.modules)),
		Assert.assertEqual("src/app.pf", firstTopoPath(ok.modules))
	])
}

//![test("toposort reports missing user modules")]
function testTopoMissingModule() {
	let app = raw("src/app.pf", [edge("./missing", ModGraph.userPath("src/missing.pf"))]);
	match ModGraph.toposort([app]) with
	| TopoOk _ -> Assert.assertions([Assert.fail("Expected missing import diagnostic.")])
	| TopoErr e -> Assert.assertions([
		Assert.assertTrue(length(e.diags) > 0)
	])
}

//![test("toposort reports import cycles")]
function testTopoCycle() {
	let a = raw("a.pf", [edge("./b", ModGraph.userPath("b.pf"))]);
	let b = raw("b.pf", [edge("./a", ModGraph.userPath("a.pf"))]);
	match ModGraph.toposort([a, b]) with
	| TopoOk _ -> Assert.assertions([Assert.fail("Expected cycle diagnostic.")])
	| TopoErr e -> Assert.assertions([
		Assert.assertTrue(length(e.diags) > 0)
	])
}
