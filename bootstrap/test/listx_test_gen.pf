// bootstrap/test/listx_test.pf — tests for bootstrap/src/data/listx.pf.

import * as Assert from "testing/assertions";
import * as ListX from "../src/data/listx";
import * from "io"; // added by gen-test-harness
import * from "testing/runner"; // added by gen-test-harness

function intListText(xs) {
	join(map(fn x => __str__(x), xs), ",")
}

function strListText(xs) {
	join(xs, "|")
}

function optionIntIs(opt, expected) {
	match opt with
	| Some found -> found.value == expected
	| None -> false
}

function foundPairIs(opt, expectedIndex, expectedValue) {
	match opt with
	| None -> false
	| Some found -> {
		found.value.key == expectedIndex
		&& found.value.value == expectedValue
	}
}

function intStrPairText(pair) {
	__str__(pair.key) ++ ":" ++ pair.value
}

function intStrPairListText(xs) {
	join(map(intStrPairText, xs), "|")
}

//![suite("data/listx")]

//![test("empty and non-empty predicates")]
function testEmptyPredicates() {
	Assert.assertions([
		Assert.assertTrue(ListX.isEmpty([])),
		Assert.assertFalse(ListX.isEmpty([1])),
		Assert.assertFalse(ListX.nonEmpty([])),
		Assert.assertTrue(ListX.nonEmpty([1]))
	])
}

//![test("append and concat preserve order")]
function testAppendAndConcat() {
	Assert.assertions([
		Assert.assertEqual(
			"1,2,3,4",
			intListText(ListX.appendL([1, 2], [3, 4]))
		),
		Assert.assertEqual(
			"1,2,3",
			intListText(ListX.appendOne([1, 2], 3))
		),
		Assert.assertEqual(
			"1,2,3,4,5",
			intListText(ListX.concat([[1, 2], [], [3], [4, 5]]))
		)
	])
}

//![test("fold, any, all, and count")]
function testFoldAndPredicates() {
	Assert.assertions([
		Assert.assertEqual(
			10,
			ListX.foldLeft(fn acc, x => acc + x, 0, [1, 2, 3, 4])
		),
		Assert.assertEqual(
			2,
			ListX.countWhere(
				fn x => x % 2 == 0,
				[1, 2, 3, 4, 5]
			)
		),
		Assert.assertTrue(ListX.any(fn x => x > 4, [1, 3, 5])),
		Assert.assertFalse(ListX.any(fn x => x > 8, [1, 3, 5])),
		Assert.assertTrue(ListX.all(fn x => x > 0, [1, 3, 5])),
		Assert.assertFalse(ListX.all(fn x => x > 2, [1, 3, 5]))
	])
}

//![test("find and index helpers")]
function testFindAndIndexHelpers() {
	let found = ListX.findBy(fn x => x > 3, [1, 2, 4, 6]);
	let missing = ListX.findBy(fn x => x > 9, [1, 2, 4, 6]);
	Assert.assertions([
		Assert.assertTrue(foundPairIs(found, 2, 4)),
		Assert.assertNone(missing),
		Assert.assertTrue(
			optionIntIs(
				ListX.indexOfBy(
					fn a, b => a == b,
					"b",
					["a", "b", "c"]
				),
				1
			)
		),
		Assert.assertNone(
			ListX.indexOfBy(
				fn a, b => a == b,
				"z",
				["a", "b", "c"]
			)
		)
	])
}

//![test("filterMap and mapWithIndex")]
function testFilterMapAndMapWithIndex() {
	Assert.assertions([
		Assert.assertEqual(
			"4,8",
			intListText(
				ListX.filterMap(
					fn x => x % 2 == 0
						? Some { x * 2 }
						: None,
					[1, 2, 3, 4]
				)
			)
		),
		Assert.assertEqual(
			"0:a|1:b|2:c",
			strListText(
				ListX.mapWithIndex(
					fn i, x => __str__(i) ++ ":" ++ x,
					["a", "b", "c"]
				)
			)
		)
	])
}

//![test("zip stops at the shorter list")]
function testZipStopsAtShorterList() {
	Assert.assertions([
		Assert.assertEqual(
			"1:a|2:b",
			intStrPairListText(
				ListX.zip([1, 2, 3], ["a", "b"])
			)
		),
		Assert.assertEqual(
			0,
			length(ListX.zip([], ["a"]))
		)
	])
}

//![test("take drop and splitAt")]
function testTakeDropSplitAt() {
	let split = ListX.splitAt(2, [1, 2, 3, 4]);
	Assert.assertions([
		Assert.assertEqual(
			"1,2",
			intListText(ListX.takeL(2, [1, 2, 3, 4]))
		),
		Assert.assertEqual(
			"3,4",
			intListText(ListX.dropL(2, [1, 2, 3, 4]))
		),
		Assert.assertEqual("1,2", intListText(split.key)),
		Assert.assertEqual("3,4", intListText(split.value)),
		Assert.assertEqual(0, length(ListX.takeL(0, [1, 2]))),
		Assert.assertEqual(
			"1,2",
			intListText(ListX.dropL(0, [1, 2]))
		)
	])
}

//![test("intersperse and sortBy")]
function testIntersperseAndSortBy() {
	Assert.assertions([
		Assert.assertEqual(
			"a|,|b|,|c",
			strListText(
				ListX.intersperse(",", ["a", "b", "c"])
			)
		),
		Assert.assertEqual(
			"1,2,3,4,5",
			intListText(
				ListX.sortBy(
					fn a, b => a - b,
					[5, 1, 4, 2, 3]
				)
			)
		),
		Assert.assertEqual(
			"5,4,3,2,1",
			intListText(
				ListX.sortBy(
					fn a, b => b - a,
					[5, 1, 4, 2, 3]
				)
			)
		)
	])
}

