function __gen_suite_data_listx() {
	suite("data/listx", [
		test("empty and non-empty predicates", testEmptyPredicates),
		test("append and concat preserve order", testAppendAndConcat),
		test("fold, any, all, and count", testFoldAndPredicates),
		test("find and index helpers", testFindAndIndexHelpers),
		test("filterMap and mapWithIndex", testFilterMapAndMapWithIndex),
		test("zip stops at the shorter list", testZipStopsAtShorterList),
		test("take drop and splitAt", testTakeDropSplitAt),
		test("intersperse and sortBy", testIntersperseAndSortBy)
	])
}

proc main() {
	runSuites([__gen_suite_data_listx()]);
}
