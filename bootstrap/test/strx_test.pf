// bootstrap/test/strx_test.pf — tests for bootstrap/src/data/strx.pf.

import * as Assert from "$PFUN_HOME/lib/testing/assertions";
import * as StrX from "../src/data/strx";

//![suite("data/strx")]

//![test("repeat handles zero one and many")]
function testRepeat() {
	Assert.assertions([
		Assert.assertEqual("", StrX.strRepeat("x", 0)),
		Assert.assertEqual("x", StrX.strRepeat("x", 1)),
		Assert.assertEqual("xxxxx", StrX.strRepeat("x", 5)),
		Assert.assertEqual("ababab", StrX.strRepeat("ab", 3))
	])
}

//![test("trim removes surrounding whitespace")]
function testTrim() {
	Assert.assertions([
		Assert.assertEqual("hello", StrX.trim("  hello  ")),
		Assert.assertEqual("hello", StrX.trimLeft("\t\nhello")),
		Assert.assertEqual("hello", StrX.trimRight("hello\n\t")),
		Assert.assertEqual("", StrX.trim(" \t\n "))
	])
}

//![test("prefix suffix and contains")]
function testPrefixSuffixContains() {
	Assert.assertions([
		Assert.assertTrue(
			StrX.startsWith("bootstrap", "boot")
		),
		Assert.assertFalse(
			StrX.startsWith("bootstrap", "strap")
		),
		Assert.assertTrue(
			StrX.endsWith("bootstrap", "strap")
		),
		Assert.assertFalse(
			StrX.endsWith("bootstrap", "boot")
		),
		Assert.assertTrue(
			StrX.contains("bootstrap", "tst")
		),
		Assert.assertFalse(
			StrX.contains("bootstrap", "zzz")
		)
	])
}

//![test("line helpers")]
function testLineHelpers() {
	Assert.assertions([
		Assert.assertEqual(
			"a\nb\nc",
			StrX.joinLines(["a", "b", "c"])
		),
		Assert.assertEqual(
			"a|b|c",
			join(StrX.splitLines("a\nb\nc"), "|")
		),
		Assert.assertEqual(
			"  a\n  b",
			StrX.indent(2, "a\nb")
		)
	])
}

//![test("replace quote padding and surrounding")]
function testReplaceQuotePaddingAndSurrounding() {
	Assert.assertions([
		Assert.assertEqual(
			"a-b-c",
			StrX.replaceAll("a.b.c", ".", "-")
		),
		Assert.assertEqual("\"hi\"", StrX.quote("hi")),
		Assert.assertEqual(
			"***hi",
			StrX.padLeft(5, "*", "hi")
		),
		Assert.assertEqual(
			"hi***",
			StrX.padRight(5, "*", "hi")
		),
		Assert.assertEqual(
			"hi",
			StrX.padLeft(1, "*", "hi")
		),
		Assert.assertEqual(
			"[hi]",
			StrX.surround("[", "]", "hi")
		)
	])
}

//![test("comma list and nullOrEmpty")]
function testCommaListAndNullOrEmpty() {
	Assert.assertions([
		Assert.assertEqual(
			"a, b, c",
			StrX.commaList(["a", "b", "c"])
		),
		Assert.assertTrue(StrX.nullOrEmpty("")),
		Assert.assertFalse(StrX.nullOrEmpty("x"))
	])
}
