// bootstrap/test/signature_grounding_test.pf
//
// Regression coverage for T2 constraining uses over exported nominal smart
// constructors. The concrete function-value anchor must close the exported
// binding without executing either function.

import * as Assert from "testing/assertions";
import * as H from "./check_helpers";
import * from "io"; // added by gen-test-harness
import * from "testing/runner"; // added by gen-test-harness

//![suite("check/types signature grounding")]
//![test("function-value anchor grounds an exported variant constructor")]
function testFunctionValueAnchorGroundsConstructor() {
	let src =
		"export type Item = { | Made: id, text };\n"
		++ "function madeSig(id, text) {\n"
		++ "  let ids = [0, id];\n"
		++ "  let texts = [\"\", text];\n"
		++ "  Made { 0, \"\" }\n"
		++ "}\n"
		++ "export function made(id, text) {\n"
		++ "  Made { id, text }\n"
		++ "}\n"
		++ "let signatures = [madeSig, made];";
	H.assertOkDiags(
		H.typeDiags(
			"signature_anchor_ok.pf",
			src
		)
	)
}

//![test("unconstrained exported constructor remains rejected")]
function testUnanchoredConstructorStillFails() {
	let src =
		"export type Item = { | Made: id, text };\n"
		++ "export function made(id, text) {\n"
		++ "  Made { id, text }\n"
		++ "}";
	H.assertHasDiag(
		H.typeDiags(
			"signature_anchor_missing.pf",
			src
		)
	)
}

// ─────────────────────────────────────────────────────────────────
// GENERATED TEST HARNESS (gen-test-harness.js) — do not edit.
// Lambda-closing lives in pure functions; the generated main has no
// lambdas, so V1's fn-lambda-in-proc purity quirk is never triggered.
// ─────────────────────────────────────────────────────────────────

function __gen_suite_check_types_signature_grounding() {
	suite("check/types signature grounding", [
		test("function-value anchor grounds an exported variant constructor", testFunctionValueAnchorGroundsConstructor),
		test("unconstrained exported constructor remains rejected", testUnanchoredConstructorStillFails)
	])
}

proc main() {
	runSuites([__gen_suite_check_types_signature_grounding()]);
}
main();
