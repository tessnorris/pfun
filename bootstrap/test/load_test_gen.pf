		test("returns lexer diagnostics", testParseOneLexError),
		test("returns parser diagnostics", testParseOneParseError)
	])
}

function __gen_suite_drivers_load_memory_graph() {
	suite("drivers/load memory graph", [
		test("loads an entry and follows relative imports", testLoadMemFollowsImports),
		test("loads duplicate imports once", testLoadMemDeduplicates),
		test("does not read builtin imports from the source map", testLoadMemSkipsBuiltins),
		test("resolves bare library imports through libDir", testLoadMemLibraryImport),
		test("reports missing in-memory source", testLoadMemMissingSource),
		test("canonicalizes source-map and entry paths", testLoadMemCanonicalPaths),
		test("produces raw modules accepted by toposort", testLoadMemTopoIntegration)
	])
}

