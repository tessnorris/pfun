function __gen_suite_builtins_spec() {
	suite("builtins/spec", [
		test("platform constructors return expected variants", testPlatformConstructors),
		test("all module specs include the bootstrap floor", testAllModuleSpecsIncludeFloor),
		test("core iface exposes builtin types and functions", testCoreIfaceExposesBuiltinTypesAndFunctions),
		test("io iface marks println as a proc", testIoIfaceMarksPrintlnAsProc),
		test("io iface exposes stderr procedures", testIoIfaceExposesStderrProcedures),
		test("intrinsic lookup returns host names", testIntrinsicLookupReturnsHostNames),
		test("file iface includes FileMode and ReadResult unions", testFileIfaceIncludesUnions),
		test("builtin iface map supports direct and core aliases", testBuiltinIfaceMapAliases)
	])
}

proc main() {
	runSuites([__gen_suite_builtins_spec()]);
}
main();
