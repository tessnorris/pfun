// bootstrap/test/diag_test.pf — unit + golden tests for check/diag.pf,
// from the architecture doc's diagnostics test list.
//
// Both suites are pure (diagnostics are data; rendering is a pure function of
// a Diag and a sourceOf lookup), so every test takes zero parameters and the
// generated main is lambda-free.
//
// The golden strings below are frozen renderings. They are the spec for the
// output format: the arch doc specifies rendering *behavior* (path/line/column,
// caret under span, sane multi-line, useful fallback) and leaves the bytes to
// the implementation, so these snapshots are what pin the bytes. Regenerate
// them deliberately, never by loosening an assertion.

import * from "testing/testing";
import * from "testing/assertions";
import * as T from "../src/syntax/token";
import * as D from "../src/check/diag";
import * as Compat from "../src/compat";

// ── source fixtures ─────────────────────────────────────────────────────────

let PARSE_SRC = "let a = 1;\nlet b = (2;\nlet c = 3;";
let TYPE_SRC  = "function add(x, y) { x + y }\nlet r = add(1, \"two\");";
let CYCLE_SRC = "import * from \"./b\";\nexport let x = 1;";
let EXH_SRC   = "type Color = { | Red | Green | Blue }\nfunction name(c) {\n  match c with\n  | Red -> \"red\"\n  | Green -> \"green\"\n}";

// sourceOf: unknown paths answer None, which exercises the fallback path.
function srcOf(path) {
	if path == "parse.pf" then { Some { PARSE_SRC } }
	else if path == "type.pf" then { Some { TYPE_SRC } }
	else if path == "a.pf" then { Some { CYCLE_SRC } }
	else if path == "color.pf" then { Some { EXH_SRC } }
	else { None }
}

// ── frozen snapshots (regenerate deliberately) ──────────────────────────────

let GOLDEN_PARSE = join([
	"parse.pf:2:11: error[Parse]: Expected ')' after expression.",
	"  let b = (2;",
	"            ^"
], "\n");

let GOLDEN_TYPE = join([
	"type.pf:2:16: error[Type]: Cannot unify Int with Str.",
	"  let r = add(1, \"two\");",
	"                 ^^^^^",
	"  note: expected Int, from add's second parameter"
], "\n");

let GOLDEN_CYCLE = join([
	"a.pf:1:1: error[Import]: Import cycle detected.",
	"  import * from \"./b\";",
	"  ^^^^^^^^^^^^^^^^^^^^",
	"  note: a.pf imports b.pf",
	"  note: b.pf imports a.pf"
], "\n");

let GOLDEN_EXHAUST = join([
	"color.pf:3:3: error[Exhaust]: Non-exhaustive match on Color.",
	"    match c with",
	"    ^^^^^^^^^^^^ (span continues for 2 more lines)",
	"  note: missing variant: Blue"
], "\n");

let PARSE_LINE = "  let b = (2;";
let PARSE_CARET = "            ^";
let TYPE_LINE = "  let r = add(1, \"two\");";
let TYPE_CARET = "                 ^^^^^";
let EXH_LINE = "    match c with";
let EXH_CARET = "    ^^^^^^^^^^^^ (span continues for 2 more lines)";
// ── helpers (bootstrap-safe subset) ─────────────────────────────────────────

function sp(l1, c1, o1, l2, c2, o2) {
	T.mkSpan(T.mkPos(l1, c1, o1), T.mkPos(l2, c2, o2))
}

function optVal(o, dflt) {
	match o with
	| None -> dflt
	| Some v -> v.value
}

function lineAt(s, i) {
	optVal(Compat.listAt(split(s, "\n"), i), "<no line " ++ __str__(i) ++ ">")
}

function lineCount(s) { length(split(s, "\n")) }

function isErrSev(sev) {
	match sev with
	| ErrSev -> true
	| WarnSev -> false
}

// The four diagnostics under snapshot. Each is built exactly as the detecting
// pass would build it: structured data, no substring classification.
function parseDiag() {
	D.err(ParseD, "Expected ')' after expression.", "parse.pf", sp(2, 11, 20, 2, 12, 21))
}

function typeDiag() {
	D.note(D.err(TypeD, "Cannot unify Int with Str.", "type.pf", sp(2, 16, 44, 2, 21, 49)),
	       "expected Int, from add's second parameter")
}

function cycleDiag() {
	D.note(D.note(D.err(ImportD, "Import cycle detected.", "a.pf", sp(1, 1, 0, 1, 21, 20)),
	              "a.pf imports b.pf"),
	       "b.pf imports a.pf")
}

function exhaustDiag() {
	D.note(D.err(ExhaustD, "Non-exhaustive match on Color.", "color.pf", sp(3, 3, 58, 5, 18, 100)),
	       "missing variant: Blue")
}

// ── unit tests ──────────────────────────────────────────────────────────────

//![suite("diag unit")]
//![test("err sets ErrSev")]
function testErrSetsErrSev() {
	let sp1 = sp(1, 1, 0, 1, 2, 1);
	let e = D.err(TypeD, "boom", "x.pf", sp1);
	let w = D.warn(TypeD, "meh", "x.pf", sp1);
	assertions([
		assertTrue(isErrSev(e.severity)),
		assertFalse(isErrSev(w.severity)),
		// a fresh diagnostic carries no notes
		assertEqual(0, length(e.notes)),
		assertEqual(0, length(w.notes))
	]);
}

//![test("note appends without mutating original")]
function testNoteImmutable() {
	let base = D.err(NameD, "Undefined variable 'x'.", "parse.pf", sp(1, 5, 4, 1, 6, 5));
	let one = D.note(base, "first");
	let two = D.note(one, "second");
	assertions([
		assertEqual(0, length(base.notes)),
		assertEqual(1, length(one.notes)),
		assertEqual(2, length(two.notes)),
		assertEqual("first", optVal(Compat.listAt(two.notes, 0), "")),
		assertEqual("second", optVal(Compat.listAt(two.notes, 1), "")),
		// the original still renders without any note line
		assertEqual(3, lineCount(D.renderDiag(base, srcOf))),
		assertEqual(5, lineCount(D.renderDiag(two, srcOf)))
	]);
}

//![test("render includes path/line/column")]
function testRenderHeader() {
	let r = D.renderDiag(parseDiag(), srcOf);
	assertions([
		assertEqual("parse.pf:2:11: error[Parse]: Expected ')' after expression.", lineAt(r, 0)),
		// a warning says so, and the code label tracks the DiagCode variant
		assertEqual("parse.pf:2:11: warning[Import]: msg",
			lineAt(D.renderDiag(D.warn(ImportD, "msg", "parse.pf", sp(2, 11, 20, 2, 12, 21)), srcOf), 0))
	]);
}

//![test("render includes caret under span")]
function testRenderCaret() {
	// single-column span: exactly one caret, under column 11 of the source line
	let p = D.renderDiag(parseDiag(), srcOf);
	// five-column span: five carets, under the string literal "two"
	let t = D.renderDiag(typeDiag(), srcOf);
	assertions([
		assertEqual(PARSE_LINE, lineAt(p, 1)),
		assertEqual(PARSE_CARET, lineAt(p, 2)),
		assertEqual(TYPE_LINE, lineAt(t, 1)),
		assertEqual(TYPE_CARET, lineAt(t, 2))
	]);
}

//![test("multi-line spans render sanely")]
function testMultiLineSpan() {
	let r = D.renderDiag(exhaustDiag(), srcOf);
	assertions([
		// only the first line of the span is shown, underlined to its end,
		// with a continuation marker rather than a multi-line drawing
		assertEqual(EXH_LINE, lineAt(r, 1)),
		assertEqual(EXH_CARET, lineAt(r, 2)),
		assertEqual(4, lineCount(r))
	]);
}

//![test("missing source still renders useful fallback")]
function testMissingSource() {
	// "gone.pf" is unknown to srcOf, so sourceOf answers None
	let d = D.note(D.warn(ImportD, "Module shadowed.", "gone.pf", sp(1, 1, 0, 1, 5, 4)),
	               "search path: lib/");
	let r = D.renderDiag(d, srcOf);
	assertions([
		// header and notes survive; only the snippet is dropped
		assertEqual("gone.pf:1:1: warning[Import]: Module shadowed.", lineAt(r, 0)),
		assertEqual("  note: search path: lib/", lineAt(r, 1)),
		assertEqual(2, lineCount(r)),
		// and rendering never fails: a line past EOF degrades the same way
		assertEqual(1, lineCount(D.renderDiag(
			D.err(TypeD, "Past EOF.", "parse.pf", sp(99, 3, 900, 99, 4, 901)), srcOf)))
	]);
}

// ── golden snapshots ────────────────────────────────────────────────────────

//![suite("diag golden")]
//![test("parse error snapshot")]
function testGoldenParse() {
	assertions([assertEqual(GOLDEN_PARSE, D.renderDiag(parseDiag(), srcOf))]);
}

//![test("type error snapshot")]
function testGoldenType() {
	assertions([assertEqual(GOLDEN_TYPE, D.renderDiag(typeDiag(), srcOf))]);
}

//![test("import cycle snapshot")]
function testGoldenCycle() {
	assertions([assertEqual(GOLDEN_CYCLE, D.renderDiag(cycleDiag(), srcOf))]);
}

//![test("match exhaustiveness snapshot")]
function testGoldenExhaust() {
	assertions([assertEqual(GOLDEN_EXHAUST, D.renderDiag(exhaustDiag(), srcOf))]);
}
