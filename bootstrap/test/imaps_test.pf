// bootstrap/test/imaps_test.pf — unit + property tests for data/imaps.pf,
// from the architecture doc's imap test list. Annotation-driven: the harness
// generator emits main; this file must not define one.
//
// Both suites are pure, so tests take zero parameters. Randomized cases use a
// deterministic LCG so every run is reproducible.

import * from "testing/testing";
import * from "testing/assertions";
import * from "../src/data/imaps";
import * as Compat from "../src/compat";

// ── helpers (bootstrap-safe subset) ─────────────────────────────────────────

function maxI(a, b) { if a > b then { a } else { b } }

function optVal(o, dflt) {
	match o with
	| None -> dflt
	| Some v -> v.value
}

// deterministic PRNG
function lcg(s) { (s * 1103515245 + 12345) % 2147483648 }

// zero-padded 3-digit key so string order matches numeric order
function pad3(n) {
	if n < 10 then { "k00" ++ __str__(n) }
	else if n < 100 then { "k0" ++ __str__(n) }
	else { "k" ++ __str__(n) }
}

function iota(n) {
	function go(i, acc) {
		if i < 0 then { acc } else { go(i - 1, cons(i, acc)) }
	}
	go(n - 1, [])
}

// AVL invariant: every node balanced and stored height correct
type Bal = { ok, h }
function balAt(m) {
	match m with
	| MLeaf -> Bal { true, 0 }
	| MNode n -> {
		let l = balAt(n.left);
		let r = balAt(n.right);
		let d = l.h - r.h;
		let h = 1 + maxI(l.h, r.h);
		Bal { l.ok && r.ok && d <= 1 && (0 - 1) <= d && n.height == h, h }
	}
}
function isBalanced(m) { balAt(m).ok }

// entries equality, elementwise on scalar fields (no structured ==)
function eqEntriesFrom(a, b, i) {
	match Compat.listAt(a, i) with
	| None -> { match Compat.listAt(b, i) with | None -> true | Some _ -> false }
	| Some ea -> {
		match Compat.listAt(b, i) with
		| None -> false
		| Some eb -> {
			if ea.value.key == eb.value.key && ea.value.value == eb.value.value
			then { eqEntriesFrom(a, b, i + 1) }
			else { false }
		}
	}
}
function eqEntries(a, b) {
	length(a) == length(b) && eqEntriesFrom(a, b, 0)
}

// keys ascending?
function ascendingFrom(ks, i) {
	match Compat.listAt(ks, i + 1) with
	| None -> true
	| Some nxt -> {
		match Compat.listAt(ks, i) with
		| None -> true
		| Some cur -> {
			if cur.value < nxt.value then { ascendingFrom(ks, i + 1) } else { false }
		}
	}
}
function ascending(ks) { ascendingFrom(ks, 0) }

// build a map from n LCG-driven inserts (keys collide on purpose: mod 50)
function buildRandom(seed, n) {
	function go(s, i, m) {
		if i >= n then { m }
		else {
			let s2 = lcg(s);
			go(s2, i + 1, imsPut(m, pad3(s2 % 50), s2 % 1000))
		}
	}
	go(seed, 0, imsEmpty())
}

// n mixed ops: ~1/3 removes, 2/3 inserts, over a colliding key space
function buildMixed(seed, n) {
	function go(s, i, m) {
		if i >= n then { m }
		else {
			let s2 = lcg(s);
			let k = pad3(s2 % 37);
			if s2 % 3 == 0 then { go(s2, i + 1, imsRemove(m, k)) }
			else { go(s2, i + 1, imsPut(m, k, s2)) }
		}
	}
	go(seed, 0, imsEmpty())
}

// ── unit tests ──────────────────────────────────────────────────────────────

//![suite("imaps unit")]
//![test("empty lookup returns None")]
function testEmptyLookup() {
	assertions([
		assertNone(imsGet(imsEmpty(), "anything")),
		assertFalse(imsHas(imsEmpty(), "anything")),
		assertEqual(0, length(imsEntries(imsEmpty())))
	]);
}

//![test("insert then get returns inserted value")]
function testInsertGet() {
	let m = imsPut(imsPut(imsPut(imsEmpty(), "b", 2), "a", 1), "c", 3);
	assertions([
		assertEqual(1, optVal(imsGet(m, "a"), 0 - 1)),
		assertEqual(2, optVal(imsGet(m, "b"), 0 - 1)),
		assertEqual(3, optVal(imsGet(m, "c"), 0 - 1)),
		assertTrue(imsHas(m, "b")),
		assertNone(imsGet(m, "d"))
	]);
}

//![test("insert same key replaces value")]
function testReplace() {
	let m = imsPut(imsPut(imsEmpty(), "k", 1), "k", 99);
	assertions([
		assertEqual(99, optVal(imsGet(m, "k"), 0 - 1)),
		assertEqual(1, length(imsEntries(m)))
	]);
}

//![test("remove deletes key")]
function testRemove() {
	let m = imsPut(imsPut(imsEmpty(), "a", 1), "b", 2);
	let m2 = imsRemove(m, "a");
	assertions([
		assertNone(imsGet(m2, "a")),
		assertFalse(imsHas(m2, "a")),
		assertEqual(2, optVal(imsGet(m2, "b"), 0 - 1)),
		assertEqual(1, length(imsEntries(m2)))
	]);
}

//![test("entries are stable sorted")]
function testEntriesSorted() {
	let m = imsFromList([Pair { "e", 5 }, Pair { "c", 3 }, Pair { "a", 1 },
	                     Pair { "d", 4 }, Pair { "b", 2 }]);
	let big = buildRandom(7, 120);
	assertions([
		assertEqual(5, length(imsEntries(m))),
		assertTrue(ascending(imsKeys(m))),
		assertTrue(ascending(imsKeys(big)))
	]);
}

//![test("AVL height invariant holds after randomized inserts/removes")]
function testAvlInvariant() {
	// sequential ascending inserts are the classic degenerate case
	function seq(i, m) {
		if i >= 64 then { m } else { seq(i + 1, imsPut(m, pad3(i), i)) }
	}
	assertions([
		assertTrue(isBalanced(seq(0, imsEmpty()))),
		assertTrue(isBalanced(buildMixed(1, 200))),
		assertTrue(isBalanced(buildMixed(1234567, 200))),
		assertTrue(isBalanced(buildMixed(987, 300)))
	]);
}

//![test("imsUnion right-biases duplicates")]
function testUnionRightBias() {
	let a = imsFromList([Pair { "only_a", 1 }, Pair { "dup", 1 }]);
	let b = imsFromList([Pair { "dup", 2 }, Pair { "only_b", 3 }]);
	let u = imsUnion(a, b);
	assertions([
		assertEqual(2, optVal(imsGet(u, "dup"), 0 - 1)),
		assertEqual(1, optVal(imsGet(u, "only_a"), 0 - 1)),
		assertEqual(3, optVal(imsGet(u, "only_b"), 0 - 1)),
		assertEqual(3, length(imsEntries(u)))
	]);
}

// ── property tests ──────────────────────────────────────────────────────────

//![suite("imaps properties")]
//![test("imsFromList(imsEntries(m)) is equivalent to m")]
function testRoundTrip() {
	function holds(seed) {
		let m = buildRandom(seed, 40);
		eqEntries(imsEntries(m), imsEntries(imsFromList(imsEntries(m))))
	}
	assertions(map(fn s => assertTrue(holds(s * 31 + 1)), iota(20)));
}

//![test("imsHas(imsPut(m,k,v),k) is true")]
function testPutHas() {
	function holds(seed) {
		let s2 = lcg(seed);
		let m = buildRandom(seed, 25);
		imsHas(imsPut(m, pad3(s2 % 200), s2), pad3(s2 % 200))
	}
	assertions(map(fn s => assertTrue(holds(s * 17 + 3)), iota(20)));
}

//![test("removing unknown key preserves existing entries")]
function testRemoveUnknown() {
	function holds(seed) {
		let m = buildRandom(seed, 30);
		// pad3 keys never collide with this one
		eqEntries(imsEntries(m), imsEntries(imsRemove(m, "zzz_absent")))
	}
	assertions(map(fn s => assertTrue(holds(s * 13 + 5)), iota(20)));
}
