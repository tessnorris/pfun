// test/check/iface_test.pf — tests for check/iface.pf.

import * as Assert from "$PFUN_HOME/lib/testing/assertions";
import * as H from "./check_helpers";
import * as Iface from "../src/check/iface";
import * as A from "../src/syntax/ast";
import * as IMS from "../src/data/imaps";
import * as Compat from "../src/compat";


function parseModule(path, source) {
	match H.parseSource(path, source) with
	| SourceOk ok -> ok.module
	| SourceErr _ -> A.mkModule(path, [], 1)
}

function ifaceFromSource(path, source) {
	Iface.ifaceOfAst(parseModule(path, source))
}

function kindName(iface, name) {
	match Iface.lookupKind(iface, name) with
	| None -> "<missing>"
	| Some k -> Iface.kindToStr(k.value)
}

function hasType(iface, name) {
	match Iface.lookupType(iface, name) with
	| None -> false
	| Some _ -> true
}

function recordFieldCount(iface, name) {
	match Iface.lookupRecord(iface, name) with
	| None -> -1
	| Some fields -> length(fields.value)
}

function unionVariantCount(iface, name) {
	match Iface.lookupUnion(iface, name) with
	| None -> -1
	| Some u -> length(u.value)
}

function firstExportName(iface) {
	match Compat.listAt(Iface.exportedNames(iface), 0) with
	| None -> "<missing>"
	| Some n -> n.value
}

//![suite("check/iface")]
//![test("empty interface has no exports")]
function testEmptyIface() {
	let iface = Iface.emptyIface("empty.pf");
	Assert.assertions([
		Assert.assertEqual("empty.pf", iface.path),
		Assert.assertFalse(Iface.hasExport(iface, "x")),
		Assert.assertEqual("<missing>", kindName(iface, "x")),
		Assert.assertFalse(hasType(iface, "x"))
	])
}

//![test("put and lookup helpers preserve interface maps")]
function testPutLookupHelpers() {
	let iface0 = Iface.emptyIface("m.pf");
	let scheme = Iface.mkScheme([], [], Iface.nameType("Int"));
	let iface1 = Iface.putKind(iface0, "answer", Iface.kValue());
	let iface2 = Iface.putType(iface1, "answer", scheme);
	Assert.assertions([
		Assert.assertTrue(Iface.hasExport(iface2, "answer")),
		Assert.assertEqual("value", kindName(iface2, "answer")),
		Assert.assertTrue(hasType(iface2, "answer")),
		Assert.assertEqual("answer", firstExportName(iface2))
	])
}

//![test("ifaceOfAst exports values functions procs and hides private names")]
function testIfaceOfAstValueAndCallableExports() {
	let source = "export let answer = 42; let hidden = 0; export function id(x) { x; } export proc run() { 0; } extern function native(x: Str) -> Int;";
	let iface = ifaceFromSource("exports.pf", source);
	Assert.assertions([
		Assert.assertEqual("value", kindName(iface, "answer")),
		Assert.assertEqual("function", kindName(iface, "id")),
		Assert.assertEqual("proc", kindName(iface, "run")),
		Assert.assertEqual("<missing>", kindName(iface, "hidden")),
		Assert.assertEqual("<missing>", kindName(iface, "native")),
		Assert.assertTrue(hasType(iface, "answer")),
		Assert.assertTrue(hasType(iface, "id")),
		Assert.assertTrue(hasType(iface, "run"))
	])
}

//![test("ifaceOfAst records exported type declarations and opaque types")]
function testIfaceOfAstTypeExports() {
	let source = "export opaque type Box = { generic value }; export type Choice = { | Yes | No }; type Hidden = { x };";
	let iface = ifaceFromSource("types.pf", source);
	Assert.assertions([
		Assert.assertEqual("opaque type", kindName(iface, "Box")),
		Assert.assertEqual("type", kindName(iface, "Choice")),
		Assert.assertEqual("<missing>", kindName(iface, "Hidden")),
		Assert.assertTrue(hasType(iface, "Box")),
		Assert.assertTrue(hasType(iface, "Choice")),
		Assert.assertEqual(1, recordFieldCount(iface, "Box")),
		Assert.assertEqual(2, unionVariantCount(iface, "Choice")),
		Assert.assertEqual(-1, unionVariantCount(iface, "Box"))
	])
}

//![test("ifaceOfChecked passes through checked maps")]
function testIfaceOfCheckedPassthrough() {
	let scheme = Iface.mkScheme([], [], Iface.nameType("Int"));
	let kinds = IMS.imsFromList([Pair { "answer", Iface.kValue() }]);
	let types = IMS.imsFromList([Pair { "answer", scheme }]);
	let records = IMS.imsFromList([
		Pair {
			"Box",
			[A.mkFieldDecl("value", true)]
		}
	]);
	let unions = IMS.imsEmpty();
	let cm = Iface.mkCheckedModuleWithRecords(
		"checked.pf",
		kinds,
		types,
		records,
		unions
	);
	let iface = Iface.ifaceOfChecked(cm);
	Assert.assertions([
		Assert.assertEqual("checked.pf", iface.path),
		Assert.assertEqual("value", kindName(iface, "answer")),
		Assert.assertTrue(hasType(iface, "answer")),
		Assert.assertEqual(1, recordFieldCount(iface, "Box"))
	])
}

//![test("ifaceOfBuiltin records builtin exports and unions")]
function testIfaceOfBuiltin() {
	let scheme = Iface.mkScheme([], [], Iface.unknownType());
	let exports = [
		Iface.mkBuiltinExport("println", Iface.kProc(), scheme),
		Iface.mkBuiltinExport("length", Iface.kFun(), scheme)
	];
	let variants = [A.mkVariantDecl("Some", [A.mkFieldDecl("value", true)]), A.mkVariantDecl("None", [])];
	let unions = [Iface.mkBuiltinUnion("Option", variants)];
	let bm = Iface.mkBuiltinModule("$builtin/core", exports, unions);
	let iface = Iface.ifaceOfBuiltin(bm);
	Assert.assertions([
		Assert.assertEqual("$builtin/core", iface.path),
		Assert.assertEqual("proc", kindName(iface, "println")),
		Assert.assertEqual("function", kindName(iface, "length")),
		Assert.assertEqual(2, unionVariantCount(iface, "Option"))
	])
}

//![test("kindToStr covers all export kinds")]
function testKindToStr() {
	Assert.assertions([
		Assert.assertEqual("function", Iface.kindToStr(Iface.kFun())),
		Assert.assertEqual("proc", Iface.kindToStr(Iface.kProc())),
		Assert.assertEqual("value", Iface.kindToStr(Iface.kValue())),
		Assert.assertEqual("mutable", Iface.kindToStr(Iface.kMutable())),
		Assert.assertEqual("type", Iface.kindToStr(Iface.kType())),
		Assert.assertEqual("opaque type", Iface.kindToStr(Iface.kOpaqueType()))
	])
}
