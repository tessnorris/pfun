// bootstrap/test/signature_grounding_test.pf
//
// Regression coverage for T2 constraining uses over exported nominal smart
// constructors. The concrete function-value anchor must close the exported
// binding without executing either function.

import * as Assert from "$PFUN_HOME/lib/testing/assertions";
import * as H from "./check_helpers";

//![suite("check/types signature grounding")]
//![test("function-value anchor grounds an exported variant constructor")]
function testFunctionValueAnchorGroundsConstructor() {
	let src =
		"export type Item = { | Made: id, text };\n"
		++ "function madeSig(id, text) {\n"
		++ "  let ids = [0, id];\n"
		++ "  let texts = [\"\", text];\n"
		++ "  Made { 0, \"\" }\n"
		++ "}\n"
		++ "export function made(id, text) {\n"
		++ "  Made { id, text }\n"
		++ "}\n"
		++ "let signatures = [madeSig, made];";
	H.assertOkDiags(
		H.typeDiags(
			"signature_anchor_ok.pf",
			src
		)
	)
}

//![test("unconstrained exported constructor remains rejected")]
function testUnanchoredConstructorStillFails() {
	let src =
		"export type Item = { | Made: id, text };\n"
		++ "export function made(id, text) {\n"
		++ "  Made { id, text }\n"
		++ "}";
	H.assertHasDiag(
		H.typeDiags(
			"signature_anchor_missing.pf",
			src
		)
	)
}
