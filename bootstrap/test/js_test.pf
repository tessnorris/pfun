// bootstrap/test/js_test.pf — Phase 12 JavaScript AST/printer tests.

import * as Assert from "$PFUN_HOME/lib/testing/assertions";
import * as J from "../src/compile/js";
import * as StrX from "../src/data/strx";

function renderExpr(e) {
	J.printJs([J.jsExprStmt(e)])
}

function testIsDigit(c) {
	c >= "0" && c <= "9"
}

function testIsLower(c) {
	c >= "a" && c <= "z"
}

function testIsUpper(c) {
	c >= "A" && c <= "Z"
}

function testIsIdStart(c) {
	testIsLower(c) || testIsUpper(c) || c == "_" || c == "$"
}

function testIsIdPart(c) {
	testIsIdStart(c) || testIsDigit(c)
}

function testValidIdFrom(name, i) {
	if i >= length(name) then {
		true
	} else {
		let c = slice(i, 1, name);
		let ok = i == 0 ? testIsIdStart(c) : testIsIdPart(c);
		if ok then {
			testValidIdFrom(name, i + 1)
		} else {
			false
		}
	}
}

function testIsValidId(name) {
	length(name) > 0 && testValidIdFrom(name, 0)
}

function allMangledNamesValid(names) {
	reduce(
		fn ok, name => ok && testIsValidId(J.mangle(name)),
		true,
		names
	)
}

function representativeProgram() {
	let values = J.jsConst(
		"values",
		J.jsArr([J.jsNum("1"), J.jsNum("2"), J.jsNum("3")])
	);

	let skipNegative = J.jsIf(
		J.jsBin(
			"<",
			J.jsIndex(J.jsId("xs"), J.jsId("i")),
			J.jsNum("0")
		),
		[
			J.jsAssign(
				J.jsId("i"),
				J.jsBin("+", J.jsId("i"), J.jsNum("1"))
			),
			J.jsContinue()
		],
		[
			J.jsAssign(
				J.jsId("total"),
				J.jsBin(
					"+",
					J.jsId("total"),
					J.jsIndex(J.jsId("xs"), J.jsId("i"))
				)
			)
		]
	);

	let stopLarge = J.jsIf(
		J.jsBin(">", J.jsId("total"), J.jsNum("100")),
		[J.jsBreak()],
		[]
	);

	let loop = J.jsWhile(
		J.jsBin(
			"<",
			J.jsId("i"),
			J.jsMember(J.jsId("xs"), "length")
		),
		[
			skipNegative,
			stopLarge,
			J.jsAssign(
				J.jsId("i"),
				J.jsBin("+", J.jsId("i"), J.jsNum("1"))
			)
		]
	);

	let sum = J.jsFun(
		"sum",
		["xs"],
		[
			J.jsLet("total", J.jsNum("0")),
			J.jsLet("i", J.jsNum("0")),
			J.jsLabel("loop", [loop]),
			J.jsRet(J.jsId("total"))
		],
		false
	);

	let guarded = J.jsTry(
		[
			J.jsConst(
				"result",
				J.jsCall(J.jsId("sum"), [J.jsId("values")])
			),
			J.jsExprStmt(
				J.jsCall(
					J.jsMember(J.jsId("console"), "log"),
					[J.jsId("result")]
				)
			)
		],
		"error",
		[J.jsThrow(J.jsId("error"))]
	);

	[values, sum, guarded]
}

function representativeExpected() {
	"const values = [1, 2, 3];\n"
	++ "function sum(xs) {\n"
	++ "  let total = 0;\n"
	++ "  let i = 0;\n"
	++ "  loop: {\n"
	++ "    while (i < xs.length) {\n"
	++ "      if (xs[i] < 0) {\n"
	++ "        i = i + 1;\n"
	++ "        continue;\n"
	++ "      } else {\n"
	++ "        total = total + xs[i];\n"
	++ "      }\n"
	++ "      if (total > 100) {\n"
	++ "        break;\n"
	++ "      }\n"
	++ "      i = i + 1;\n"
	++ "    }\n"
	++ "  }\n"
	++ "  return total;\n"
	++ "}\n"
	++ "try {\n"
	++ "  const result = sum(values);\n"
	++ "  console.log(result);\n"
	++ "} catch (error) {\n"
	++ "  throw error;\n"
	++ "}\n"
}

//![suite("compile/js literals and identifiers")]
//![test("escapes JavaScript strings")]
function testStringEscaping() {
	let source = J.printJs([
		J.jsConst(
			"text",
			J.jsStr("quote \" slash \\ line\n tab\t")
		)
	]);

	Assert.assertions([
		Assert.assertEqual(
			"const text = \"quote \\\" slash \\\\ line\\n tab\\t\";\n",
			source
		)
	])
}

//![test("prints numeric boolean and null literals")]
function testLiteralPrinting() {
	Assert.assertions([
		Assert.assertEqual(
			"const a = 0.5;\n"
			++ "const b = 9007199254740993n;\n"
			++ "const c = true;\n"
			++ "const d = null;\n",
			J.printJs([
				J.jsConst("a", J.jsNum(".5")),
				J.jsConst("b", J.jsBig("9007199254740993")),
				J.jsConst("c", J.jsBool(true)),
				J.jsConst("d", J.jsNull())
			])
		)
	])
}

//![test("mangles reserved and invalid identifiers deterministically")]
function testMangleExamples() {
	Assert.assertions([
		Assert.assertEqual("alpha_2", J.mangle("alpha_2")),
		Assert.assertEqual(
			"$pf$99_108_97_115_115",
			J.mangle("class")
		),
		Assert.assertEqual(
			"$pf$104_97_115_45_100_97_115_104",
			J.mangle("has-dash")
		),
		Assert.assertEqual("$pf$empty", J.mangle("")),
		Assert.assertTrue(
			J.mangle("$pf$99") != "$pf$99"
		)
	])
}

//![test("mangle always produces valid JavaScript identifiers")]
function testMangleValidity() {
	Assert.assertions([
		Assert.assertTrue(
			allMangledNamesValid([
				"x",
				"_x2",
				"$tmp",
				"class",
				"await",
				"has-dash",
				"two words",
				"9lives",
				"",
				"$pf$collision"
			])
		)
	])
}

//![suite("compile/js expressions")]
//![test("preserves binary and logical precedence")]
function testPrecedence() {
	Assert.assertions([
		Assert.assertEqual(
			"a + b * c;\n",
			renderExpr(
				J.jsBin(
					"+",
					J.jsId("a"),
					J.jsBin("*", J.jsId("b"), J.jsId("c"))
				)
			)
		),
		Assert.assertEqual(
			"(a + b) * c;\n",
			renderExpr(
				J.jsBin(
					"*",
					J.jsBin("+", J.jsId("a"), J.jsId("b")),
					J.jsId("c")
				)
			)
		),
		Assert.assertEqual(
			"a - (b - c);\n",
			renderExpr(
				J.jsBin(
					"-",
					J.jsId("a"),
					J.jsBin("-", J.jsId("b"), J.jsId("c"))
				)
			)
		),
		Assert.assertEqual(
			"(a ** b) ** c;\n",
			renderExpr(
				J.jsBin(
					"**",
					J.jsBin("**", J.jsId("a"), J.jsId("b")),
					J.jsId("c")
				)
			)
		),
		Assert.assertEqual(
			"a ** b ** c;\n",
			renderExpr(
				J.jsBin(
					"**",
					J.jsId("a"),
					J.jsBin("**", J.jsId("b"), J.jsId("c"))
				)
			)
		),
		Assert.assertEqual(
			"a || b && c;\n",
			renderExpr(
				J.jsLogic(
					"||",
					J.jsId("a"),
					J.jsLogic("&&", J.jsId("b"), J.jsId("c"))
				)
			)
		)
	])
}

//![test("parenthesizes JavaScript grammar edge cases")]
function testGrammarEdgeCases() {
	Assert.assertions([
		Assert.assertEqual(
			"(-x) ** y;\n",
			renderExpr(
				J.jsBin(
					"**",
					J.jsUn("-", J.jsId("x")),
					J.jsId("y")
				)
			)
		),
		Assert.assertEqual(
			"(a ?? b) || c;\n",
			renderExpr(
				J.jsLogic(
					"||",
					J.jsLogic("??", J.jsId("a"), J.jsId("b")),
					J.jsId("c")
				)
			)
		),
		Assert.assertEqual(
			"a ?? (b && c);\n",
			renderExpr(
				J.jsLogic(
					"??",
					J.jsId("a"),
					J.jsLogic("&&", J.jsId("b"), J.jsId("c"))
				)
			)
		),
		Assert.assertEqual(
			"({value: 1}.value);\n",
			renderExpr(
				J.jsMember(
					J.jsObj([
						J.jsProp("value", J.jsNum("1"))
					]),
					"value"
				)
			)
		),
		Assert.assertEqual(
			"const data = {[\"__proto__\"]: null};\n",
			J.printJs([
				J.jsConst(
					"data",
					J.jsObj([
						J.jsProp("__proto__", J.jsNull())
					])
				)
			])
		)
	])
}

//![test("prints arrays objects calls new members and indexes")]
function testCompositeExpressions() {
	let obj = J.jsObj([
		J.jsProp(
			"ok",
			J.jsArr([
				J.jsNum("1"),
				J.jsBool(true),
				J.jsNull()
			])
		),
		J.jsProp(
			"dash-name",
			J.jsNew(J.jsId("Box"), [J.jsStr("x")])
		)
	]);

	Assert.assertions([
		Assert.assertEqual(
			"const data = {ok: [1, true, null], "
			++ "\"dash-name\": new Box(\"x\")};\n"
			++ "const first = data.ok[0];\n"
			++ "const weird = data[\"dash-name\"];\n"
			++ "const method = (1).toString;\n",
			J.printJs([
				J.jsConst("data", obj),
				J.jsConst(
					"first",
					J.jsIndex(
						J.jsMember(J.jsId("data"), "ok"),
						J.jsNum("0")
					)
				),
				J.jsConst(
					"weird",
					J.jsMember(J.jsId("data"), "dash-name")
				),
				J.jsConst(
					"method",
					J.jsMember(J.jsNum("1"), "toString")
				)
			])
		)
	])
}

//![test("prints async arrows with expression and block bodies")]
function testArrowPrinting() {
	Assert.assertions([
		Assert.assertEqual(
			"const load = async (x) => await fetch(x);\n"
			++ "const step = (x) => {\n"
			++ "  const y = x + 1;\n"
			++ "  return y;\n"
			++ "};\n"
			++ "const make = () => ({value: 1});\n",
			J.printJs([
				J.jsConst(
					"load",
					J.jsArrow(
						["x"],
						J.jsExprBody(
							J.jsAwait(
								J.jsCall(
									J.jsId("fetch"),
									[J.jsId("x")]
								)
							)
						),
						true
					)
				),
				J.jsConst(
					"step",
					J.jsArrow(
						["x"],
						J.jsBlockBody([
							J.jsConst(
								"y",
								J.jsBin(
									"+",
									J.jsId("x"),
									J.jsNum("1")
								)
							),
							J.jsRet(J.jsId("y"))
						]),
						false
					)
				),
				J.jsConst(
					"make",
					J.jsArrow(
						[],
						J.jsExprBody(
							J.jsObj([
								J.jsProp("value", J.jsNum("1"))
							])
						),
						false
					)
				)
			])
			)
	])
}

//![test("prints conditional assignment unary and await expressions")]
function testOtherExpressions() {
	Assert.assertions([
		Assert.assertEqual(
			"target = ready ? await load() : !failed;\n",
			renderExpr(
				J.jsAssignExpr(
					J.jsId("target"),
					J.jsCond(
						J.jsId("ready"),
						J.jsAwait(
							J.jsCall(J.jsId("load"), [])
						),
						J.jsUn("!", J.jsId("failed"))
					)
				)
			)
		)
	])
}

//![suite("compile/js statements and golden output")]
//![test("prints empty programs and blocks stably")]
function testEmptyPrinting() {
	Assert.assertions([
		Assert.assertEqual("", J.printJs([])),
		Assert.assertEqual(
			"function empty() {}\n",
			J.printJs([
				J.jsFun("empty", [], [], false)
			])
		),
		Assert.assertEqual(
			"if (ready) {}\n",
			J.printJs([
				J.jsIf(J.jsId("ready"), [], [])
			])
		)
	])
}

//![test("representative AST matches golden JavaScript")]
function testRepresentativeGolden() {
	Assert.assertions([
		Assert.assertEqual(
			representativeExpected(),
			J.printJs(representativeProgram())
		)
	])
}

//![test("printer output never contains accidental undefined text")]
function testNoUndefinedText() {
	let printed = J.printJs([
		J.jsConst("x", J.jsArr([])),
		J.jsExprStmt(J.jsObj([])),
		J.jsBlock([]),
		J.jsIf(J.jsBool(true), [], [])
	]);

	Assert.assertions([
		Assert.assertFalse(StrX.contains(printed, "undefined")),
		Assert.assertFalse(StrX.contains(printed, "[object Object]")),
		Assert.assertTrue(length(printed) > 0)
	])
}
