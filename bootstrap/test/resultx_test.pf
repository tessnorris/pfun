// bootstrap/test/resultx_test.pf — tests for bootstrap/src/data/resultx.pf.

import * as Assert from "testing/assertions";
import * from "../src/data/resultx";

function bOkIntIs(result, expected) {
	match result with
	| BOk ok -> ok.value == expected
	| BErr _ -> false
}

function bOkStrIs(result, expected) {
	match result with
	| BOk ok -> ok.value == expected
	| BErr _ -> false
}

function bErrIs(result, expected) {
	match result with
	| BOk _ -> false
	| BErr err -> err.message == expected
}

function optionIntIs(opt, expected) {
	match opt with
	| Some found -> found.value == expected
	| None -> false
}

function intListText(xs) {
	join(map(fn x => __str__(x), xs), ",")
}

function bOkIntListIs(result, expectedText) {
	match result with
	| BOk ok -> intListText(ok.value) == expectedText
	| BErr _ -> false
}

//![suite("data/resultx")]

//![test("constructors and predicates")]
function testConstructorsAndPredicates() {
	Assert.assertions([
		Assert.assertTrue(isOk(ok(1))),
		Assert.assertFalse(isOk(err("bad"))),
		Assert.assertTrue(isErr(err("bad"))),
		Assert.assertFalse(isErr(ok(1)))
	])
}

//![test("mapResult and mapErr")]
function testMapResultAndMapErr() {
	Assert.assertions([
		Assert.assertTrue(
			bOkIntIs(
				mapResult(fn x => x + 1, BOk { 3 }),
				4
			)
		),
		Assert.assertTrue(
			bErrIs(
				mapResult(fn x => x + 1, BErr { "bad" }),
				"bad"
			)
		),
		Assert.assertTrue(
			bErrIs(
				mapErr(
					fn message => message ++ "!",
					BErr { "bad" }
				),
				"bad!"
			)
		),
		Assert.assertTrue(
			bOkIntIs(
				mapErr(
					fn message => message ++ "!",
					BOk { 3 }
				),
				3
			)
		)
	])
}

//![test("andThenResult and withDefault")]
function testAndThenAndDefault() {
	Assert.assertions([
		Assert.assertTrue(
			bOkIntIs(
				andThenResult(
					BOk { 3 },
					fn x => BOk { x * 2 }
				),
				6
			)
		),
		Assert.assertTrue(
			bErrIs(
				andThenResult(
					BErr { "bad" },
					fn x => BOk { x * 2 }
				),
				"bad"
			)
		),
		Assert.assertEqual(3, withDefault(0, BOk { 3 })),
		Assert.assertEqual(0, withDefault(0, BErr { "bad" }))
	])
}

//![test("option conversion")]
function testOptionConversion() {
	Assert.assertions([
		Assert.assertTrue(
			optionIntIs(toOption(BOk { 3 }), 3)
		),
		Assert.assertNone(toOption(BErr { "bad" })),
		Assert.assertTrue(
			bOkIntIs(
				fromOption("missing", Some { 3 }),
				3
			)
		),
		Assert.assertTrue(
			bErrIs(
				fromOption("missing", None),
				"missing"
			)
		)
	])
}

//![test("combine keeps first error and otherwise returns right")]
function testCombine() {
	Assert.assertions([
		Assert.assertTrue(
			bOkStrIs(
				combine(
					BOk { "left" },
					BOk { "right" }
				),
				"right"
			)
		),
		Assert.assertTrue(
			bErrIs(
				combine(
					BErr { "left bad" },
					BOk { "right" }
				),
				"left bad"
			)
		),
		Assert.assertTrue(
			bErrIs(
				combine(
					BOk { "left" },
					BErr { "right bad" }
				),
				"right bad"
			)
		)
	])
}

//![test("collect accumulates values or first error")]
function testCollect() {
	Assert.assertions([
		Assert.assertTrue(
			bOkIntListIs(
				collect([
					BOk { 1 },
					BOk { 2 },
					BOk { 3 }
				]),
				"1,2,3"
			)
		),
		Assert.assertTrue(
			bErrIs(
				collect([
					BOk { 1 },
					BErr { "bad" },
					BOk { 3 }
				]),
				"bad"
			)
		)
	])
}
