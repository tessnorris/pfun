// test/load_test.pf — Phase 16 graph-loader tests.

import * as Assert from "testing/assertions";
import * as Load from "../src/drivers/load";
import * as MG from "../src/graph/modgraph";
import * as Compat from "../src/compat";

function env() {
	MG.mkSearchEnv(
		"bootstrap/src/stdlib",
		".",
		["io", "file", "json", "math"]
	)
}

function source(path, text) {
	MG.mkSourceFile(path, text)
}

function sourceMap(files) {
	Load.sourceMapFromFiles(files)
}

function containsText(text, needle) {
	match findSlice(text, needle) with
	| None -> false
	| Some _ -> true
}

function containsModule(modules, path) {
	match Compat.uncons(modules) with
	| None -> false
	| Some cell -> {
		if cell.value.key.path == path then { true }
		else {
			containsModule(
				cell.value.value,
				path
			)
		}
	}
}

function firstModulePath(modules) {
	match Compat.listAt(modules, 0) with
	| None -> "<missing>"
	| Some m -> m.value.path
}

function secondModulePath(modules) {
	match Compat.listAt(modules, 1) with
	| None -> "<missing>"
	| Some m -> m.value.path
}

function firstEdgeText(module) {
	match Compat.listAt(module.edges, 0) with
	| None -> "<missing>"
	| Some edge -> MG.resolvedPathToStr(
		edge.value.resolved
	)
}

function firstDiagMessage(diags) {
	match Compat.listAt(diags, 0) with
	| None -> "<missing diagnostic>"
	| Some diag -> diag.value.message
}

//![suite("drivers/load parseOne")]
//![test("lexes parses and extracts edges")]
function testParseOneSuccess() {
	let text =
		"import * as IO from \"io\"; "
		++ "import * as Dep from \"./dep\"; "
		++ "let x = 1;";

	match Load.parseOne("src/main", text, env()) with
	| ParseOneErr e -> Assert.assertions([
		Assert.fail(
			"Expected parseOne success, got "
			++ __str__(length(e.diags))
			++ " diagnostics."
		)
	])
	| ParseOneOk ok -> Assert.assertions([
		Assert.assertEqual("src/main.pf", ok.module.path),
		Assert.assertEqual(2, length(ok.module.edges)),
		Assert.assertEqual(
			"$builtin/io",
			firstEdgeText(ok.module)
		)
	])
}

//![test("returns lexer diagnostics")]
function testParseOneLexError() {
	match Load.parseOne(
		"bad-lex.pf",
		"let x = \"unterminated;",
		env()
	) with
	| ParseOneOk _ -> Assert.assertions([
		Assert.fail("Expected lexer diagnostics.")
	])
	| ParseOneErr e -> Assert.assertions([
		Assert.assertTrue(length(e.diags) > 0),
		Assert.assertTrue(
			containsText(
				firstDiagMessage(e.diags),
				"Unterminated string"
			)
		)
	])
}

//![test("returns parser diagnostics")]
function testParseOneParseError() {
	match Load.parseOne(
		"bad-parse.pf",
		"let x = ;",
		env()
	) with
	| ParseOneOk _ -> Assert.assertions([
		Assert.fail("Expected parser diagnostics.")
	])
	| ParseOneErr e -> Assert.assertions([
		Assert.assertTrue(length(e.diags) > 0)
	])
}

//![suite("drivers/load memory graph")]
//![test("loads an entry and follows relative imports")]
function testLoadMemFollowsImports() {
	let files = sourceMap([
		source(
			"src/main.pf",
			"import * as Dep from \"./dep\"; let x = 1;"
		),
		source(
			"src/dep.pf",
			"import * as Leaf from \"./leaf\"; "
			++ "export function dep() { 2 }"
		),
		source(
			"src/leaf.pf",
			"export function leaf() { 3 }"
		)
	]);

	match Load.loadGraphMem(
		files,
		"./src/main",
		env()
	) with
	| LoadErr e -> Assert.assertions([
		Assert.fail(
			"Expected graph success, got "
			++ __str__(length(e.diags))
			++ " diagnostics."
		)
	])
	| LoadOk ok -> Assert.assertions([
		Assert.assertEqual(3, length(ok.modules)),
		Assert.assertTrue(
			containsModule(ok.modules, "src/main.pf")
		),
		Assert.assertTrue(
			containsModule(ok.modules, "src/dep.pf")
		),
		Assert.assertTrue(
			containsModule(ok.modules, "src/leaf.pf")
		)
	])
}

//![test("loads duplicate imports once")]
function testLoadMemDeduplicates() {
	let files = sourceMap([
		source(
			"src/main.pf",
			"import * as A from \"./dep\"; "
			++ "import * as B from \"./dep\"; "
			++ "let x = 1;"
		),
		source(
			"src/dep.pf",
			"export function dep() { 2 }"
		)
	]);

	match Load.loadGraphMem(
		files,
		"src/main.pf",
		env()
	) with
	| LoadErr _ -> Assert.assertions([
		Assert.fail("Expected duplicate imports to load.")
	])
	| LoadOk ok -> Assert.assertions([
		Assert.assertEqual(2, length(ok.modules))
	])
}

//![test("does not read builtin imports from the source map")]
function testLoadMemSkipsBuiltins() {
	let files = sourceMap([
		source(
			"main.pf",
			"import * as IO from \"io\"; let x = 1;"
		)
	]);

	match Load.loadGraphMem(
		files,
		"main.pf",
		env()
	) with
	| LoadErr _ -> Assert.assertions([
		Assert.fail("Expected builtin import to be skipped.")
	])
	| LoadOk ok -> Assert.assertions([
		Assert.assertEqual(1, length(ok.modules)),
		Assert.assertTrue(
			containsModule(ok.modules, "main.pf")
		)
	])
}

//![test("resolves bare library imports through libDir")]
function testLoadMemLibraryImport() {
	let files = sourceMap([
		source(
			"src/main.pf",
			"import * as W from \"widgets\"; "
			++ "import * as A from "
			++ "\"testing/assertions\"; "
			++ "let x = 1;"
		),
		source(
			"bootstrap/src/stdlib/widgets.pf",
			"export function widget() { 1 }"
		),
		source(
			"bootstrap/src/testing/assertions.pf",
			"export function assertion() { 2 }"
		)
	]);

	match Load.loadGraphMem(
		files,
		"src/main.pf",
		env()
	) with
	| LoadErr _ -> Assert.assertions([
		Assert.fail(
			"Expected stdlib and public namespace "
			++ "imports to load."
		)
	])
	| LoadOk ok -> Assert.assertions([
		Assert.assertEqual(3, length(ok.modules)),
		Assert.assertTrue(
			containsModule(
				ok.modules,
				"bootstrap/src/stdlib/widgets.pf"
			)
		),
		Assert.assertTrue(
			containsModule(
				ok.modules,
				"bootstrap/src/testing/assertions.pf"
			)
		)
	])
}

//![test("reports missing in-memory source")]
function testLoadMemMissingSource() {
	let files = sourceMap([
		source(
			"src/main.pf",
			"import * as Missing from \"./missing\"; "
			++ "let x = 1;"
		)
	]);

	match Load.loadGraphMem(
		files,
		"src/main.pf",
		env()
	) with
	| LoadOk _ -> Assert.assertions([
		Assert.fail("Expected missing-source diagnostic.")
	])
	| LoadErr e -> Assert.assertions([
		Assert.assertTrue(length(e.diags) > 0),
		Assert.assertTrue(
			containsText(
				firstDiagMessage(e.diags),
				"src/missing.pf"
			)
		)
	])
}

//![test("canonicalizes source-map and entry paths")]
function testLoadMemCanonicalPaths() {
	let files = sourceMap([
		source(
			"./src/ui/../main",
			"let x = 1;"
		)
	]);

	match Load.loadGraphMem(
		files,
		"src/./main",
		env()
	) with
	| LoadErr _ -> Assert.assertions([
		Assert.fail("Expected canonical source lookup.")
	])
	| LoadOk ok -> Assert.assertions([
		Assert.assertEqual(1, length(ok.modules)),
		Assert.assertEqual(
			"src/main.pf",
			firstModulePath(ok.modules)
		)
	])
}

//![test("produces raw modules accepted by toposort")]
function testLoadMemTopoIntegration() {
	let files = sourceMap([
		source(
			"src/main.pf",
			"import * as Dep from \"./dep\"; let x = 1;"
		),
		source(
			"src/dep.pf",
			"export function dep() { 2 }"
		)
	]);

	match Load.loadGraphMem(
		files,
		"src/main.pf",
		env()
	) with
	| LoadErr _ -> Assert.assertions([
		Assert.fail("Expected loader success.")
	])
	| LoadOk loaded -> {
		match MG.toposort(loaded.modules) with
		| TopoErr _ -> Assert.assertions([
			Assert.fail("Expected toposort success.")
		])
		| TopoOk sorted -> Assert.assertions([
			Assert.assertEqual(
				"src/dep.pf",
				firstModulePath(sorted.modules)
			),
			Assert.assertEqual(
				"src/main.pf",
				secondModulePath(sorted.modules)
			)
		])
	}
}
