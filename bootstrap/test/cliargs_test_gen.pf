		test("parses build with the default output", testDefaultBuild),
		test("parses build with -o", testShortOutputFlag),
		test("parses build with --output", testLongOutputFlag),
		test("rejects an unknown command", testUnknownCommand),
		test("rejects missing and extra arguments", testWrongArity),
		test("rejects an unknown output flag", testUnknownOutputFlag)
	])
}

function __gen_suite_drivers_cliargs_environment_policy() {
	suite("drivers/cliargs environment policy", [
		test("defaults PFUN_HOME to the working directory", testHomeDefault)
	])
}

function __gen_suite_drivers_cliargs_path_policy() {
	suite("drivers/cliargs path policy", [
		test("joins home-relative paths", testJoinPath),
